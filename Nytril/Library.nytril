class PartitionRateAction: Action {
  var RateData         Rate;
  var SegmentPartition Partition;
  var Taxon            Taxon;
  var                  Count,
                       Percent;

  Constructor(RateData rate, SegmentPartition partition, count, percent) {
    super.Constructor(Actions.RunQuery, null);
    Partition = partition;
    Taxon     = rate.Taxon;
    Count     = count;
    Percent   = percent;
  }

  override GetQuery = MatchAll(CognateWord) {
    MatchAny(WorldLanguage) {
      Taxon.Language;
    };
    MatchAny(VocalSegment) {
      Partition.Segments;
    };
  };

  override GetLayoutTip = VBox {
    HAlign: Center;
    Span {
      Lang.Occurrences(Count);
      Space;
      Span {
        "(";
        TextDigits: 1;
        Percent * 100.0;
        "%)";
      }
    };
  };
}

//======================================================================

class PartitionFrequencyChart: FrequencyChart {
  Constructor(ExperimentData data) {
    super.Constructor(data, data.Rule.Partitions.Length);

    foreach (var cognate in data.UsedCognates) {
      foreach (var word in cognate.Words) {
        var rate = Rates[word.Taxon.Index];
        foreach (var segment in word.Segments) {
          ++rate.TotalCount;
          ++rate.Count[segment.PartitionIndex];
        }
      }
    }

    ComputeDistance(@CompareFrequency);
  }

  override SegmentBar(RateData rate, index, width, height) {
    var f = rate.Frequency[index].Frequency / rate.MaxFrequency;
    return Canvas(width-1, height * f) {
      Margin: PadR(1);
      var partition = Partitions[index];
      Background: partition.BackColor;
      TipAction: new PartitionRateAction(rate, partition, rate.Count[index], f);
    };
  }

  PartitionLabel(index, width, height) = Frame(width, height) {
    ParAlignment: Center;
    Partitions[index].Name;
  };

  override OccurranceChart(Size size) = MatrixBox {
    var lw = 60pt;
    var cw = size.Width - lw;
    var bw = cw / Partitions.Length;
    var bh = 16pt;
    var h  = (size.Height - bh) / Taxa.Length;
    var r0 = SortedRates[0];

    TextHeight: 11pt;
    VAlign: Bottom;

    var factor = 1.0 / MaxDistance;
    foreach (var rate in SortedRates) {
      Row {
        Cell(PadR(3pt)) {
          Frame(lw) {
            rate.Taxon.Language;
          };

          var frac = factor * rate.Distance;
          Canvas(lw * frac, 2) {
            Background: Colors.Red;
            Tip: new Tip("{0}% different from {1}"(frac*100.0 {TextDigits: 1}, r0.Taxon.Language));
          };
        };
        LangCanvas(rate, bw, h);
      };
    }

    Row {
      Empty;
      TextHeight: 9pt;
      HBox {
        VAlign: Top;
        PartitionLabel(each SortedIndexes, bw, bh);
      };
    }
  };
}

