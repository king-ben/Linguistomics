class FrequencyFigure: Content {
  var FrequencyChart Chart;

  Constructor(FrequencyChart chart, title) {
    super.Constructor(title);
    Chart = chart;
  }

  override GetBody(ContentStyle style) = Chart.ShowChart(style);
}

