class Taxon {
  var               ShortName,
                    Index,
                    WordCount,
                    SegmentCount;
  var WorldLanguage Language;

  Constructor(WorldLanguage language) {
    Index        = each0;
    Language     = language;
    ShortName    = language.ShortName;
    WordCount    = 0;
    SegmentCount = 0
  }

  override GetLayoutTip = Span {
    PaperStyle.TaxonFormat;
    Language.Name;
    TipAction: Language;
  };
}

//======================================================================

class WordPairClass {
  var             Index;
  var CognateWord Word1,
                  Word2;

  Constructor(index, CognateWord w1, CognateWord w2) {
    Index = index;
    Word1 = w1;
    Word2 = w2;
  }

  ShowDescription(textheight) = Frame(null, null, 0.25pt) {
    TextHeight: textheight;
    Paragraph {
      ParBackground: 90%;
      Word1.Cognate.GetTitle;
    };

    Word1.ShowPaddedBlocks(textheight, Index);
    Word2.ShowPaddedBlocks(textheight, Index);
  };

  override GetLayoutTip = ShowDescription(12pt);
}

//======================================================================

class ExperimentData {
  var WorldLanguage[]         LanguageSet;
  var SegmentPart[]           UniqueSegments;
  var Cognate[]               SortedCognates;
  var List<Concept>           UsedConcepts;
  var List<Cognate>           UsedCognates;
  var Vector<CognateWord>     WordList;
  var List<SegmentPart>       SegmentBuffer;
  var Taxon[]                 Taxa;
  var StringDictionary<Taxon> TaxonSet;
  var PartitionRule           Rule;
  var CognateWord             DefWord;
  var TreeSet[]               TreeSets;
  var List<char>              PlainBuffer,
                              TextBuffer;
  var Attribute               ExampleConcept,
                              FigureConcept,
                              DataConcept;
  var                         RunNumbers,
                              WordCutoff,
                              RootFolder,
                              Name,
                              MaxLanguageName,
                              WordCount,
                              SegmentCount,
                              WordFile;
  var bool                    RawData;

  Constructor(config, name, rootfolder, runnumbers) {
    Name            = name;
    RootFolder      = Folder(rootfolder);
    RunNumbers      = runnumbers;
    WordFile        = RootFolder Info.WordFileName;
    WordCount       = 0;
    SegmentCount    = 0;
    MaxLanguageName = 0;
    TextBuffer      = new(64);
    PlainBuffer     = new(64);
    SegmentBuffer   = new(64);
    Rule            = new NaturalPartition;
    TreeSets        = AddTree(config, each TreeExamples.PriorTrees);
    if (config is null)
      ReadExperiment;
  }

  TreeSet AddTree(config, Node root) = new(config, "Tree"+each1, RootFolder, root, 1..1);

  void ReadRawWords(Attribute concepts, includewords, WorldLanguage[] languageset, cutoff=-1) {
    RawData = true;

    if (cutoff < 0)
      cutoff = languageset.Length;
    WordCutoff = cutoff;

    AddLanguageSet(languageset);
    UsedCognates = new(1024);
    UsedConcepts = new(256);

    foreach (var cvar in concepts.Children) {
      var conceptvar = cvar.Value;
      var confidence = conceptvar.?Confidence ?? 0;
      var good       = exists conceptvar.?WordType and
                       exists conceptvar.?WordGroup;
      System.Assert(good, "Improper concept", conceptvar);

      if (good and confidence > 0 and conceptvar.WordGroup.HasFlag(includewords)) {
        var concept = new Concept(cvar);
        concept.CheckRaw;
        UsedConcepts.Add(concept);

        foreach (var cc in cvar.Children) {
          var vname = cc.Name;
          if (vname != "Confidence" and vname != "WordType" and vname != "WordGroup") {
            var count = 0;
            foreach (var wc in cc.Children) {
              var word = wc.Value;
              if (word is valid) {
                var taxon = TaxonSet.GetValue(wc.Name);
                if (taxon is valid)
                  ++count;
              }
            }

            if (count >= cutoff)
              UsedCognates.Add(new(concept, cc));
          }
        }
      }
    }

    UsedConcepts.Sort(false);

    var lookup = new SegPartDictionary(VocalSegments.Length);
    foreach (var segment in VocalSegments) {
      if (segment.Ipa is valid)
        lookup.Add(new SegmentPart(segment), segment.Ipa);
    }

    foreach (var cognate in UsedCognates)
      ComputeRawCognate(lookup, cognate);

    var set = new SegmentSet(512);
    foreach (var cognate in UsedCognates) {
      foreach (var word in cognate.Words) {
        foreach (var segment in word.Segments) {
          if (!segment.Punctuation)
            set.Add(segment);
        }
      }
    }
    UniqueSegments = set.ToArray;

    GetConceptExamples(concepts);
    CompletedRead;
  }

  void ReadExperiment {
    var run = ReadScript(Info.ExperimentRoot WordFile).Root;

    WordCutoff  = run.Info.WordCutoff;
    AddLanguageSet(run.LanguageSet);

    var slist  = new List<SegmentPart>(run.Segments.Length);
    var lookup = new StringDictionary<VocalSegment>(VocalSegments.Length);
    foreach (var segment in VocalSegments) {
      if (segment.Ipa is valid)
        lookup.Add(segment, segment.Ipa);
    }

    foreach (var text in run.Segments) {
      var s = lookup.GetValue(text);
      if (s is valid)
        slist.Add(new SegmentPart(s));
      else
        System.Assert(false, "Missing Segment " + text);
    }

    UniqueSegments = slist.ToArray;

    var concepts = attribute(run.Concepts);
    UsedConcepts = new(concepts.Length);
    UsedCognates = new(concepts.Length * 2);

    foreach (var cvar in concepts.Children) {
      var concept = new Concept(cvar);
      UsedConcepts.Add(concept);

      foreach (var cognatevar in cvar.Children) {
        var cognate = new Cognate(concept, cognatevar);
        UsedCognates.Add(cognate);
        ComputeExperimentCognate(cognate, cognatevar);
      }
    }

    GetConceptExamples(concepts);
    CompletedRead;
  }

  void AddLanguageSet(WorldLanguage[] languageset) {
    LanguageSet = languageset;
    TaxonSet    = new(LanguageSet.Length);

    List<Taxon> tlist = new(LanguageSet.Length);

    foreach (var l in LanguageSet) {
      l.LangIndex = each0;

      var taxon = new Taxon(l);
      var name  = l.ShortName;
      tlist.Add(taxon);
      TaxonSet.Add(taxon, name);
      if (name.Length > MaxLanguageName)
        MaxLanguageName = name.Length;
    }
    Taxa     = tlist.ToArray;
    WordList = new(Taxa.Length, null);
    DefWord  = new(#71f32657-a37c-4f1d-abba-87b928e9d80b#, Empty, Taxa[0], null);
    DefWord.Init;
  }

  virtual void GetConceptExamples(Attribute concepts) {
    ExampleConcept = concepts.FindChild("Stone");
    FigureConcept  = concepts.FindChild("What");
    DataConcept    = concepts.FindChild("Mountain");
  }

  void CompletedRead {
    foreach (var segment in UniqueSegments) {
      segment.Index         = each0;
      segment.UsedFrequency = segment.UsedCount / SegmentCount;
    }

    Rule.Init(UniqueSegments);
  }

  Coverage(Taxon taxon) {
    var index = taxon.Index;
    var count = 0.0;
    var used  = 0.0;
    foreach (var c in UsedCognates) {
      var word = c.Words[index];
      if (word is valid and word.Text is valid)
        ++used;

      ++count;
    }
    return used / count;
  }

  Cognate[] GetSortedCognates {
    SortedCognates ??= UsedCognates.ToArray;
    return SortedCognates;
  }

  Cognate GetCognate(Attribute concept) = UsedCognates.FindFirst(c => c.Concept.Name == concept.Name);

  void ComputeRawCognate(SegPartDictionary lookup, Cognate cognate) {
    WordList.Initialize(DefWord);
    var maxlength = 0;
    foreach (var tvar in cognate.Attribute.Children) {
      var text  = tvar.Value;
      var taxon = TaxonSet.GetValue(tvar.Name);
      if (taxon is valid) {
        var word = new CognateWord(Guid.FromHash(text+cognate.Concept.Name+cognate.Name+taxon.ShortName), text, taxon, cognate);
        word.InitRaw(text, lookup);
        maxlength = Math.Max(maxlength, word.Aligned.Length);

        int count = 0;
        foreach (var s in word.Segments) {
          if (s.Index >= 0) {
            ++count;
            ++s.UsedCount;
          }
        }


        SegmentCount         += count;
        taxon.SegmentCount   += count;
        WordList[taxon.Index] = word;
      }
    }

    cognate.Words     = WordList.ToArray;
    cognate.MaxLength = maxlength;

    foreach (var word in cognate.Words) {
      var a = word.Aligned;
      if (a is valid) {
        if (a.Length < maxlength)
          word.Padded = a + [IPAParts.Gap] * (maxlength - a.Length);
        else
          word.Padded = a;
      }
      else
        word.Padded = a;
    }

    for (var i = 0; i < maxlength; ++i) {
      var count    = 0;
      var gapcount = 0;

      foreach (var word in cognate.Words) {
        if (word.Aligned is valid) {
          ++count;
          if (word.Padded[i] == IPAParts.Gap)
            ++gapcount;
        }
      }
      System.Assert(gapcount < count, "Column with all gaps", cognate.Attribute);
    }
  }

  void ComputeExperimentCognate(Cognate cognate, Attribute cognatevar) {
    WordList.Initialize(DefWord);

    var maxlength = 0;
    foreach (var word in cognatevar.Value) {
      if (word is valid) {
        var taxon = Taxa[each0];
        if (taxon is valid) {
          ++taxon.WordCount;
          ++WordCount;

          TextBuffer.Clear();
          PlainBuffer.Clear();
          SegmentBuffer.Clear();

          var gs    = IPAParts.Gap;
          var gap   = gs.Ipa[0];
          var count = 0;
          foreach (var index in word) {
            if (index < 0) {
              TextBuffer.Add(gap);
              SegmentBuffer.Add(gs);
            }
            else {
              var s = UniqueSegments[index];
              SegmentBuffer.Add(s);
              foreach (var c in s.Ipa) {
                TextBuffer.Add(c);
                PlainBuffer.Add(c);
              }
              ++s.UsedCount;
              ++count;
            }
          }

          SegmentCount       += count;
          taxon.SegmentCount += count;


          var text = Span {TextBuffer.ToArray} as string;
          var w    = new CognateWord(Guid.FromHash(text+cognate.Concept.Name+cognate.Name+taxon.ShortName), text, taxon, cognate);
          w.InitExperiment(word, SegmentBuffer.ToArray);
          if (w.Aligned.Length > maxlength)
            maxlength = w.Aligned.Length;
          WordList[taxon.Index] = w;
        }
      }
    }

    cognate.Words     = WordList.ToArray;
    cognate.MaxLength = maxlength;
  }

  ShowWord(SegmentPart segment) = Block {
    Paragraph(BorderB(1)) {
      SpaceBefore: 10pt;
      TextHeight: 14;
      "Words containing \"{0}\""(segment.Ipa);
    };
    Paragraph {
      PaperStyle.IPAFamily;
      Separator: Space;
      foreach (var cognate in UsedCognates) {
        foreach (var word in cognate.Words) {
          if (word.Segments.FindElementIndex(segment) >= 0)
            word.ShowPlain;
        }
      }
    };
  };

  Node NumberedTree = new NBranch(17) {
    new NLeaf(Latin, 1, 6);
    new NBranch(16) {
      new NLeaf(Romanian, 2, 5);
      new NBranch(15) {
        new NBranch(13) {
          new NLeaf(Friulian, 3, 3);
          new NLeaf(Italian, 4, 3);
        };
        new NBranch(14) {
          new NBranch(11) {
            new NLeaf(Catalan, 5, 2);
            new NBranch(10) {
              new NLeaf(Portuguese, 6, 1);
              new NLeaf(Spanish, 7, 1);
            };
          };
          new NBranch(12) {
            new NLeaf(French, 8, 2);
            new NLeaf(Walloon, 9, 2);
          };
        };
      }
    }
  };

  override Icon GetIcon = Icons.science;
}

//======================================================================

abstract class CountBase {
  var               VFlags,
                    MaxDigits;
  var SegmentPart[] LegendSegments;

  Constructor(ExperimentData data) {
    VFlags         = SegmentFeatures.Vowel | SegmentFeatures.Semivowel;
    LegendSegments = data.Rule.Segments;
    MaxDigits      = 3;
  }

  PartitionBox(ContentStyle style, Size extentsize) = Paragraph {
    style.SansSerif;

    var grid   = 0.125pt;
    var gcolor = 65%;
    var border = 0.5pt;
    var mx     = Math.Min(extentsize.Width, Math.Max(extentsize.Height, 6")) - border*2;
    var size   = new Size(mx, mx);
    var length = LegendSegments.Length;
    var d      = size / (length+1);

    Canvas(null, null, border) {
      TextHeight: Math.Min(d.Height * 0.7, d.Width * 1.7 / MaxDigits);

      var y = d.Height;
      for (var i = 0; i < length; ++i) {
        var x = d.Width;
        for (var j = 0; j < length; ++j) {
          AddEntry(LegendSegments[i], LegendSegments[j], x, y, d);
          x += d.Width;
        }
        y += d.Height;
      }

      y = d.Height;
      var p = 0;
      foreach (var s in LegendSegments) {
        Canvas(d.Width, d.Height) {
          Y: y;
          Background: s.Partition.BackColor;
          TextColor: s.Partition.TextColor;
          HAlign: Center;
          VAlign: Center;
          s.ShowSegment;
        };
        if (p != s.PartitionIndex) {
          Canvas(size.Width, grid) {
            Y: y;
            Background: gcolor;
          };
          p = s.PartitionIndex;
        }
        y += d.Height;
      }

      Canvas(size.Width, d.Height) {
        var x = d.Width;
        p = 0;
        foreach (var s in LegendSegments) {
          Canvas(d.Width, d.Height) {
            X : x;
            Background: s.Partition.BackColor;
            TextColor: s.Partition.TextColor;
            HAlign: Center;
            VAlign: Center;
            s.ShowSegment;
          };
          if (p != s.PartitionIndex) {
            Canvas(grid, size.Height) {
              X: x;
              Background: gcolor;
            };
            p = s.PartitionIndex;
          }
          x += d.Width;
        }
      };
    };
  };

  abstract AddEntry(SegmentPart si, SegmentPart sj, x, y, Size size);
}

//======================================================================

class TransitionAction: DocumentEntry {
  var WordPairClass[] List;
  var                 Percent;

  Constructor(SegmentPart s1, SegmentPart s2, WordPairClass[] list, percent) {
    super.Constructor(Guid.FromHash(s1.Ipa + s2.Ipa), Actions.ToDocument);
    List    = list;
    Percent = percent;
  }

  ShowSegments(count) = Block {
    var first = List.FirstElement;
    Paragraph {
      first.Word1.Padded[first.Index].ShowSegment;
      Tex.To;
      first.Word2.Padded[first.Index].ShowSegment;
    };
    Paragraph {
      List.Length; " transitions";
    };
    Paragraph {
      TextDigits: 1;
      Percent * 100.0;
      Lang.PercentOfMax;
    };

    Paragraph {
      Separator: Space;
      foreach (var p in List[0..<count])
        p.ShowDescription(10pt);
    };

    if (count < List.Length)
      "More...";
  };

  override GetDocument = Block {
    ShowSegments(List.Length);
  };

  override GetLayoutTip {
    var count = Math.Min(List.Length, 30);
    return Frame(Math.Min(count*3, 6) inches) {
      ShowSegments(count);
    };
  }
}

//======================================================================

class PriorCount: CountBase {
  typedef WordPairList List<WordPairClass>;

  var Matrix<WordPairList> TMatrix;
  var                      Factor;

  Constructor(ExperimentData data) {
    super.Constructor(data);

    var count = data.UniqueSegments.Length;
    TMatrix   = new(count, count, null);
    MaxDigits = 4;

    var tmax = 1;

    foreach (var cognate in data.UsedCognates) {
      var length = cognate.Words.Length;
      for (var i = 0; i < length; ++i) {
        var pi = cognate.Words[i].Padded;
        for (var j = 0; j < length; ++j) {
          if (i != j) {
            var pj = cognate.Words[j].Padded;
            var ml = Math.Min(pi.Length, pj.Length);
            for (var index = 0; index < ml; ++index) {
              var si = pi[index];
              var sj = pj[index];
              if (si != sj and not si.Punctuation and not sj.Punctuation) {
                var list = TMatrix[si.Index, sj.Index];
                var p    = new WordPairClass(index, cognate.Words[i], cognate.Words[j]);
                if (list is null) {
                  list = new WordPairList(128);
                  TMatrix[si.Index, sj.Index] = list;
                }
                list.Add(p);
                if (list.Length > tmax)
                  tmax = list.Length;
              }
            }
          }
        }
      }
    }
    Factor = 1.0 / tmax;
  }

  override AddEntry(SegmentPart si, SegmentPart sj, x, y, Size size) {
    var value = TMatrix[si.Index, sj.Index];
    if (value is null)
      return null;

    return Canvas(size.Width, size.Height) {
      X: x;
      Y: y;
      HAlign: Center;
      VAlign: Center;
      TipNoPublish: true;
      TipAction: new TransitionAction(si, sj, value.ToArray, value.Length*Factor);

      var count = 0;
      foreach (var e in value) {
        var c0 = e.Word1.Padded[e.Index];
        var c1 = e.Word2.Padded[e.Index];
        if (c0.Features.HasFlag(VFlags) != c1.Features.HasFlag(VFlags))
          ++count;
      }

      var bf = count > 0 ? 0.5 * count / value.Length : 0.5 + 0.5 * value.Length * Factor;
      var bc = PaperStyle.HeatMap.InterpolateColor(bf);

      Background: bc;
      TextColor: bc.TextCompliment;
      if (value.Length > 0)
        value.Length;
    };
  }
}

