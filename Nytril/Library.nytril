using Format, Units, IO, LinkTypes, WorldLanguages;

//======================================================================

class AlignData {
  var Prob,
      WordSet;

  Constructor(prob, wordset) {
    Prob    = prob;
    WordSet = wordset;
  }

  override GetLayoutTip = Span {
    TextDigits: 2;
    "{0}% probability"(Prob*100);
  };
}

//======================================================================

class AlignIndexClass {
  var             ConceptName,
                  CognateName;
  var Cognate     Cognate;
  var AlignData[] Alignments;
  var int         TotalCount;

  Constructor(concept, cognate, AlignData[] alignments, total) {
    TotalCount  = total;
    ConceptName = concept;
    CognateName = cognate ?? DefaultCognate;
    Alignments  = alignments;
  }

  string FullName {
    if (CognateName == DefaultCognate)
      return ConceptName;
    return "{0}-{1}"(ConceptName, CognateName);
  }

  string TableName {
    var b = new StringBuilder;
    foreach (var c in ConceptName) {
      if (each0 > 0 and c.IsUpper)
        b.Append(Space);
      b.Append(c);
    }
    return b.ToString;
  }
}

//======================================================================

RateDescriptor(text) = Span {
  text;
};

//======================================================================

class AlignPairClass: DocumentEntry {
  var ExperimentData Data;
  var AlignData[]    Alignments;
  var Size           BoxSize;
  var                TableName;

  Constructor(ExperimentData data, AlignIndexClass cognate) {
    super.Constructor(Guid.FromHash("Align" + cognate.FullName), cognate.FullName);

    Data       = data;
    Alignments = cognate.Alignments;
    TableName  = cognate.TableName;
    BoxSize    = new Size(14pt, 14pt);
  }

  Languages(data, height) = VBox {
    HAlign: Right;
    HBox(null, height);

    foreach (var taxon in data.Taxa) {
      HBox(null, height) {
        VAlign: Center;
        taxon.Language;
      };
    }
  };

  ShowBlock(prob, cumulative, wordset, boxheight) = VBox(null, null, new Edge(0.125, 0, 50%)) {
    Margin: PadB(6pt);
    HAlign: Center;

    HBox(null, boxheight) {
      Span {
        TextSignificant: true;
        TextDigits: 3;
        prob;
        if (prob != cumulative) {
          " (";
          cumulative;
          ")";
        }
      }
    };

    VBox {
      foreach (var taxon in Data.Taxa) {
        HBox(null, boxheight) {
          var word = wordset[each0];
          if (word is valid) {
            foreach (var c in word) {
              Canvas(BoxSize.Width, BoxSize.Height) {
                HAlign: Center;
                SegmentPart part;
                if (c == -1)
                  part = IPAParts.Gap;
                else if (c >= 0 and c < Data.UniqueSegments.Length) {
                  part = Data.UniqueSegments[c];
                  Background: part.Partition.BackColor;
                  TextColor: part.Partition.TextColor;
                }
                else
                  part = IPAParts.Missing;
                part.ShowSegment(System.IsDesktop);
              };
            }
          }
        };
      }
    };
  };

  override GetLayoutTip = ShowDetails(9, true, 10pt);

  override GetDocument = ShowDetails(50, true, 10pt);

  GetChart(Size size, int max) = Chart(size.Width, size.Height) {
    TextHeight: 6pt;
    ValueLabel: PaperStyle.ValueLabel {
      "Probability";
    };
    ValueAxis: ChartAxis {
      TextSignificant: false;
      TextDigits: 1;
      Start: 0.0;
      Stop: 1.0;
    };
    ChartSeries {
      ChartType: ChartTypes.Column;
      foreach (var a in Alignments) {
        new DataPoint(each0, a.Prob) {Reference: a.Prob};
        if (each1 >= max)
          break;
      }
    };
  };

  ShowDetails(max, tip, textheight) = Block {
    TextHeight: textheight;

    Paragraph(null, [3"]) {
      KeepWithNext: true;
      TextHeight: textheight + 4pt;
      SpaceAfter: 10pt;
      Name;
    };

    if (Alignments.Length > 1)
      GetChart(new(3", 0.75"), max);

    var langbox = Languages(Data, BoxSize.Height);
    var indent  = GetLayoutSize(langbox).Width;
    Paragraph {
      if (tip) {
        langbox;
        Space;
      }
      else {
        LeftIndent: indent;
        FirstIndent: -indent;
        Tab;
        langbox;
      }

      double cumulative = 0.0;
      ShowBlocks(Alignments, max, BoxSize.Height, ref cumulative);
    }
  };

  ShowAll = Block {
    var textheight = 8pt;
    var height     = 10pt;
    var max        = 9;
    BoxSize = new(BoxSize.Width, height);

    TextHeight: textheight;

    Paragraph(null, [3"]) {
      KeepWithNext: true;
      TextHeight: textheight + 4pt;
      SpaceAfter: 10pt;
      HBox(100%) {
        Justify: Justifiers.SpaceBetween;
        TableName;
        if (Alignments.Length > 1)
          GetChart(new(3", 0.75"), max);
      };
    };

    Paragraph {
      Separator: Space;
      Languages(Data, height);
      double cumulative = 0.0;
      ShowBlocks(Alignments, max, height, ref cumulative);
    };
  };

  ShowBlocks(AlignData[] alignments, max, boxheight, ref double cumulative) = {
    foreach (var a in alignments) {
      var prob = a.Prob;
      cumulative += prob;
      var wordset = a.WordSet;
      if (wordset.Length > 0) {
        ShowBlock(prob, cumulative, wordset, boxheight);
        if (each1 >= max)
          break;
      }
    }
  };

  ShowFigureDetails(ExperimentData data, int max, int blocks) = Block {
    var chart = 1.25";
    var h     = 7pt;
    BoxSize = new(BoxSize.Width, h);
    TextHeight: h * 0.80;
    HBox(ExtentWidth) {
      Separation: 10pt;
      GetChart(new(chart, data.Taxa.Length * (h + 1)), max);

      double cumulative = 0.0;
      VBox(ExtentWidth - chart - 15) {
        foreach (var a in Alignments[0..<Math.Min(max, Alignments.Length)] / blocks) {
          HBox(100%) {
            Justify: Justifiers.SpaceBetween;
            if (each0 == 0)
              Languages(Data, h);
            ShowBlocks(a, blocks, h, ref cumulative);
          };
        }
      };
    }
  };

  ShowFigureData(AlignIndexClass index, AlignData align) = Frame {
    var h = 8pt;
    BoxSize = new(BoxSize.Width, h);
    Paragraph {
      SpaceBefore: 6pt;
      TextHeight: 12pt;
      index.Cognate.GetTitle;
    };

    Paragraph {
      TextHeight: 7pt;
      Span {
        Languages(Data, h);
        ShowBlock(align.Prob, align.Prob, align.WordSet, h);
      }
    };
  };
}

//======================================================================

class WorldLanguage: Fact {
  field string Name;
  var Image    Image;
  var int      Cases;
  var string   ShortName;
  var int      LangIndex;
  var          ImagePath;
  var Color    MapColor;

  Constructor(id, name, cases=0, imagepath=null) {
    super.Constructor(id);
    Name      = name;
    ShortName = name.Replace(" ", Empty);
    Cases     = cases;
    ImagePath = imagepath;
  }

  override Icon GetIcon = Icons.language;

  virtual Description = null;

  override GetLayoutSpan = Span {
    TipAction: this;
    Name;
  };

  ShowMap(width, height) {
    if (ImagePath is null)
      return null;

    Image ??= new Image(ImagePath);
    return FitBox(Image, width, height);
  }

  override GetLayoutTip = Frame(4") {
    Paragraph {
      Bold;
      TextHeight: 14pt;
      Name;
    };
    Paragraph {
      ParAlignment: Justify;
      Description;
    };
    Paragraph {
      ParAlignment: Center;
      ShowMap(ExtentWidth, 2");
    };
  };

  override GetLayoutNode = HBox(null, null, new Edge(0.25pt, 1, 80%) + PadLR(3)) {
    BorderRadius: 3;
    Background: Colors.Bisque;
    Name;
  };
}

//======================================================================

class CognateWord: Fact {
  field string       Text;
  var WorldLanguage  Language;
  var Taxon          Taxon;
  var Cognate        Cognate;
  var SegmentPart[]  Segments,
                     Aligned,
                     Padded;
  var                Variable;

  Constructor(Guid id, text, Taxon taxon, Cognate cognate) {
    super.Constructor(id);
    Text     = text;
    Taxon    = taxon;
    Language = taxon.Language;
    Cognate  = cognate;
  }

  override GetSourceReference = Variable;

  override Icon GetIcon = Icons.text_format;

  void Init {
    Segments = [];
    Aligned  = [];
  }

  void InitRaw(variable, SegPartDictionary lookup) {
    // IPA text and word text must be in the same unicode normaization form so comparisons are accurate
    Variable = variable;

    if (Text is valid) {
      Text = string.Normalize(Text, NormalizationForms.FormC);

      var segments = lookup.FindTokens(Text, IPA.NullSegment);
      Aligned  = segments.FindSlice(s => s.Segment.Gap or (not s.Punctuation));
      Segments = segments.FindSlice(s => not s.Punctuation);

      foreach (var s in Segments)
        s.Index = each0;

      // Test that the word's text is the same as the segments converted back into text
      var view = Span {(each segments).Ipa};
      System.Assert(Text == (view as string), "Round-trip error with text {0}-{1}"(Text, view), Text);
      Connect;
    }
    else
      Init;
  }

  void InitExperiment(variable, SegmentPart[] segments) {
    Variable = variable;
    Aligned  = segments;
    Padded   = segments;
    Segments = segments.FindSlice(s => not s.Punctuation);
    Connect;
  }

  void Connect {
    Link.Connect(this, (each Segments).Segment);
    Link.Connect(this, Cognate);
    Link.Connect(this, Language);
//    Link.Connect(Language, Cognate); This is probably not needed since words are linked to their language
  }

  ShowPlain = LitSpan {
    PaperStyle.IPAFamily;

    Action: new Action(Actions.ToSource, Variable);
    // Strip out gaps and stress characters
    Text.FindSlice(c => c != VocalSegments.GapSegment.Ipa and c != VocalSegments.PrimaryStress.Ipa) as string;
  };

  ShowPadded = Span {
    foreach (var segment in Padded)
      segment.ShowSegment;
  };

  ShowPaddedBlocks(textheight, index=-1) = HBox {
    TextHeight: textheight;

    foreach (var segment in Padded) {
      HBox(textheight*1.125, null, BorderL(new(0.125pt, 0, 80%))) {
        HAlign: Center;
        if (index == each0)
          Background: Colors.LightYellow;
        segment.ShowSegment;
      };
    }
  };

  FieldPar(name) = Paragraph(null, [0.5"]) {
    Bold name;
    Tab;
  };

  override GetLayoutSpan = Span {
    PaperStyle.IPAFamily;
    foreach (var s in Segments) {
      if (!s.Punctuation)
        s.Ipa;
    }
  };

  override GetLayoutNode = HBox(null, null, new Edge(0.25pt, 1, 80%) + PadLR(3)) {
    Action: new Action(Actions.ToSource, Variable);
    BorderRadius: 3;
    Background: 95%;
    ShowPlain;
  };

  override GetLayoutTip = Block {
    FieldPar(Lang.Language) {
      Language;
    };
    FieldPar(Lang.Cognate) {
      Cognate.GetTitle;
    };
    FieldPar(Lang.Segments) {
      Frame(null, null, 0.5) {
        ShowPaddedBlocks(16pt);
      }
    }
  };

  override GetLayoutFact = Block {
    Paragraph(null, [1", 2", 3", 4"]) {
      GetIcon;
      Space;
      Quote;
      ShowPlain;
      Quote;
      Tab;
      Language;
      ColonSpace;
      Cognate.GetTitle;
    };
  };
}

//======================================================================

class Concept: Fact {
  field string   Name;
  field double   Confidence;
  var Attribute  Attribute;
  var            Variable;
  var WordTypes  WordType;
  var WordGroups WordGroup;

  Constructor(Attribute a) {
    super.Constructor(Guid.FromHash(a.FullName));
    Attribute = a;
    Variable  = a.Value;
    Name      = a.Name;
  }

  override GetSourceReference = Variable;

  void CheckRaw {
    var v = Attribute.Value;
    Confidence = v.Confidence;
    WordType   = v.WordType;
    WordGroup  = v.WordGroup;

    System.Assert(Confidence > 0);
    System.Assert(WordType != WordTypes.None);
    System.Assert(WordGroup != WordGroups.None);
  }

  GetTitle = Span {
    Name;
    Action: new Action(Actions.ToSource, Attribute.Value);
  };

  override Icon GetIcon = Icons.category;

  override GetLayoutTip = Block {
    Span {Lang.Concept; ColonSpace; Name};
    if (Confidence > 0)
      Span{"Confidence"; ColonSpace; Confidence};
  };

  override int Compare(c) {
    return Name.Compare(c.Name);
  }
}

//======================================================================

class Cognate: Fact {
  field string       Name;
  var Concept        Concept;
  var CognateWord[]  Words;
  var                MaxLength;
  var Attribute      Attribute;

  Constructor(Concept concept, Attribute cognate) {
    super.Constructor(Guid.FromHash(cognate.FullName));

    Name      = cognate.Name;
    Attribute = cognate;
    Concept   = concept;
    MaxLength = 0;

    Link.Connect(this, concept);
  }

  override Icon GetIcon = Icons.format_list_bulleted;

  override GetSourceReference = Attribute;

  GetSource = Span {
    Concept.Name;
    if (Name != DefaultCognate) {
      '-';
      Name;
    }
  };

  GetTitle = GetSource {
    Action: new Action(Actions.ToSource, Attribute.Value);
  };

  override int Compare(c) {
    var i = Concept.Compare(c.Concept);
    if (i == 0)
      return Name.Compare(c.Name);
    return i;
  }

  ConceptName = Span {
    var n = Attribute.Name;
    Concept.Name;
    if (n != DefaultCognate)
      Span {TextHeight: 60%; n};
  };

  override GetLayoutNode = VBox(null, null, new Edge(0.25pt, 1, 90%) + PadLR(3)) {
    BorderRadius: 3;
    Background: #007F00#;
    TextColor: Colors.White;
    ConceptName;
  };

  override GetLayoutTip = Block {
    TextHeight: 20pt;
    Paragraph {
      Lang.Concept;
      ColonSpace;
      Concept.Name;
    };
    Paragraph {
      Lang.Cognate;
      ColonSpace;
      Attribute.Name;
    };
  };
}

