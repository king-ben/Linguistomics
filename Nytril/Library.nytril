class RateDataClass {
  var TaxonClass       Taxon;
  var Vector      Count;
  var FrequencyClass[] Frequency;
  var                  TotalCount,
                       MaxFrequency,
                       Distance;

  Constructor(count, TaxonClass taxon) {
    Taxon        = taxon;
    TotalCount   = 0;
    MaxFrequency = 0;
    Count        = new Vector(count, 0);
  }
}

