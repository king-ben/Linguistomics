class FrequencyFigureClass: ContentClass {
  var FrequencyChartClass Chart;

  Constructor(FrequencyChartClass chart, title) {
    super.Constructor(title);
    Chart = chart;
  }

  override GetBody(ContentStyleClass style, title) = Chart.ShowChart(style);
}

