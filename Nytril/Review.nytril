using Format;

readonly ReviewDocument Main.Documents.Review = new;

readonly namespace<Person> Reviewers {
  R1 = new(#c2af5714-c3da-4e59-af0e-d6b1b181db8e#, "Reviewer 1", null, null);
  R2 = new(#8afa017a-9e98-42ef-9052-006768cbb043#, "Reviewer 2", null, null);
  R3 = new(#e72f0c0e-25f1-4751-9d75-a722c5392850#, "Reviewer 3", null, null);
}


class Comment: Fact {
  field string Text;
  var        Formatted;
  var Person Reviewer;
  var        Response;
  field bool NoAction,
             HasAnchor;

  Constructor(Guid id, Person reviewer) {
    super.Constructor(id);
    Reviewer = reviewer;
  }

  override Icon GetIcon = Icons.comment;

  override GetLayoutTip = Block {
    TextHeight: 14pt;
    Paragraph {
      ParBackground: Colors.LightGray;
      Reviewer.First;
    };
    ShowText;
  };

  ShowText = Block {
    Block {
      ParAlignment: Justify;
      if (NoAction)
        TextColor: Colors.DarkGray;
      Text;
      if (NoAction) Paragraph {
        "No Action Needed";
      };
    };

    var p = FindFacts(Person) as Person[];
    if (p is valid) {
      Span {
        TextColor: Colors.DarkGreen;
        "Assigned to ";
        CommaList {
          (each p).First;
        };
      };
    }

    var region = FindFirstFact(DocumentEntry);
    if (region is valid)
      region;

    if (Response is valid) Block {
      Bold "Response";
      Paragraph(BorderLR(new(1, 5, Colors.LightGray))) {
        LeftIndent: 16pt;
        RightIndent: 16pt;
        Response;
      }
    };

  };

  ShowReview(ContentStyle style) = Block {
    style.Heading2 {
      ParBackground: Colors.LightGray;
      each1; ")"; Tab;
      Reviewer.First;
    };
    ShowText;
    if (HasAnchor) {
      Paragraph {
        Span {
          TextColor: Colors.Blue;
          "Go to location";
          Action: new Action(Actions.ToDocAnchor, "{0}/{1}"(Main.Documents.PaperJOLE.FactId, FactId));
        };
      };
    }
  };
}

AssignedTo(Person p) = {LinkTypes.Link to p};


ReviewComment(Comment c) = {DocFields.Anchor(c.FactId); LinkTypes.Link to c; Span {TextColor: Colors.Blue; Icons.comment; Tip: c; Action: new Action(ToSource, c, c.FactId)}};
ReviewOld                = Span {TextColor: Colors.Red; TextStrike: TextStrikes.Single};
ReviewNew                = Span {TextColor: Colors.Blue};


// For example
//  ReviewNew {
//    "new text"
//  };
//  ReviewOld {
//    "Old text";
//  };


readonly namespace<Comment> Comments {
  C1 = new(#24e42fab-cc77-4fff-b209-f3c5abb3bcc3#, Reviewers.R1) {
    Text: Paragraph {
      "In this article the author propose to model the phonological evolution of word forms through time, and to infer jointly the phonological changes and the phylogeny of the tree (actually it seems the authors only select the topology from 3 proposed topologies). ";
      "They propose several models and manage to compute a Bayes factor, which is a very good addition to the paper in my opinion. The main positive point of the model in my opinion is that the alignment of the word forms is automatic and a side produce of the inference. ";
      "The main negative point in my opinion is the lack of importance given to H: depending on the choice of the prior on this parameter we can get extremely different results.";
    };
    NoAction: true;
  };

  C2 = new(#c728912c-ed60-40c3-b780-93a4c0cb10fc#, Reviewers.R1) {
    Text: Paragraph {
      "Two articles come to my mind as comparison points for this work: the first is Bouchard-Cˆot´e’s one (2013) that is cited but not enough commented in my opinion. ";
      "The current article uses TKF91 as a base for their inference, while Bouchard-Cˆot´e comments on this model that it lacks expressiveness, and I would agree with this comment. ";
      "Obviously, as Bouchard-Cˆot´e mostly wants to infer the ancestral states, it is possible to use a more complex model.";
    };
    AssignedTo(People.Goldstein_David);
    Response: Paragraph {
      "I think this a wonderful suggestion, and I will act on it immediately. ";
    };
  };

  C3 = new(#daf1e77c-7961-4769-a348-66ab6fc951c8#, Reviewers.R1) {
    Text: Paragraph {
      "The second article would be Abner (2024) ”Computational phylogenetics reveal histories of sign languages”, which is closer in the goal but uses different assumptions on the model.";
    };
  };

  C4 = new(#d0fe979b-9bf2-43cd-af5a-e2bc05c2bfda#, Reviewers.R1) {
    Text: Paragraph {
      "I don’t think a direct comparison with any of those model is doable or interesting (although you mention that TKF91 is not primarily used to infer the phylogeny and thus Bouchard-Cˆot´e is your direct competitor), but I would think some more questions can be asked based on those articles (I am not a specialist of Romance languages so some remarks might just mean additional details on the specificities of this domain is needed). ";
      "I mention those questions in the next parts.";
    };
  };

  C5 = new(#9628d19f-a73c-4513-8f75-b7d6fe7122b3#, Reviewers.R1) {
    Text: Paragraph {
      "I think the article would benefit from more care in the writing. ";
      "Some figures are not referred in the text (e.g. ";
      "fig 11). For more clarity, a small table could summarize models M1,M2 and M3. These models could also be mentionned earlier. ";
      "It is not entirely clear to me how are the parameters of M3 designed, it looks to me as a type of hierarchical model.";
    };
    AssignedTo(People.Huelsenbeck_John);
    HasAnchor: true;
    Response: Paragraph {
      "A reference to Figure 11 is found in section 4.4 par-2. ";
    };
  };

  C6 = new(#98b6f99a-d855-488f-8567-04ae6bf4ab41#, Reviewers.R1) {
    Text: Paragraph {
      "Concerning the environment influence. ";
      "In Bouchard-Côté they use transducer to retranscribe some of these interactions. ";
      "In your model another 1 possibility would be to use a different segmentation: for example align /k/ with /sj/, which would I guess be the best option here.";
    };
  };

  C7 = new(#bba1563a-d9e3-4583-a553-5c144d26ee9c#, Reviewers.R1) {
    Text: Paragraph {
      "Another frequent assumption is the regularity of the changes (as you mention in 5.2, ";
      "although the context cannot explain itself the regularity in a probabilistic point of view). ";
      "As it is a common assumption. ";
      "More concretely in the computation of the likelihood, without this assumption the proximity of two languages for which systematically /a/ corresponds to /e/ would be further away. ";
      "Is the size of the dataset related with the arguably good results of the method? ";
      "Or is it only because you select from three highly likely phylogenies.";
    };
  };

  C8 = new(#83492b5e-b204-4774-90f8-dfd2b7bd0fe6#, Reviewers.R1) {
    Text: Paragraph {
      "Another model that would be interesting to compare are the ”phylogenies” inferred using Levenshtein distances, as your model corresponds to a weighted levenshtein distance by some aspects.";
    };
    AssignedTo(People.Huelsenbeck_John);
  };

  C9 = new(#6151e5d5-7e71-443f-b618-3c88754e44c8#, Reviewers.R1) {
    Text: Paragraph {
      "Assuming three topologies can be justified in the Romance example, but is not doable in general. ";
      "Are there possibilities to infer fully the topology of the tree?";
    };
    AssignedTo(People.Huelsenbeck_John);
  };

  C10 = new(#51c66272-7832-41ed-98b9-e4ea9976a413#, Reviewers.R1) {
    Text: Paragraph {
      "A last question would be the set of possible sounds in the changes. ";
      "What happens if the ancestral language contains sounds that have never been preserved but explains the strange patterns observed in the data?";
    };
    AssignedTo(People.Huelsenbeck_John);
  };

  C11 = new(#72b822fe-704b-471b-97ee-27d71ebc619e#, Reviewers.R1) {
    Text: Paragraph {
      "Lexical innovation is particularly important in linguistics, in the example presented there is little to no innovation. ";
      "Is that why the author chose this example? ";
      "In Bouchard-Côté they infer jointly the cognacy classes and the transducers, would that be possible (or at least added as another step) in your model, or in future studies? ";
      "There is an extensive literature on those models (Dollo model by Nicholls and Gray; Gray and Atkinson, etc.). ";
      "I don’t think these models are related directly to your article, but the second paragraph of 5.5 tells a different story.";
    };
    AssignedTo(People.Goldstein_David);
    HasAnchor: true;
  };

  C12 = new(#f7dbaafc-a909-45d2-a231-bb2e225531f1#, Reviewers.R1) {
    Text: Paragraph {
      "I don’t understand this sentence in the conclusion “When applied to abstract cognate relationships, it is not clear what exactly is being counted along the branches.” ";
      "as the models I mention above are clear on what they count, the lack of clarity might be on the definition of the cognacy classes and their production from the original data. ";
      "Note also that these models are event based as well.";
    };
  };

  C13 = new(#04cf0c5e-2b71-4158-ab28-be3e9bf4aa68#, Reviewers.R1) {
    Text: Paragraph {
      "The sentence “who also treat cognate word-forms as observations” concerning Bouchard-Côté, is false as they extend their method to the case of unknown cognacy classes as well. ";
      "The sentence “model is a historical model with well-defined events that can transform a word” is also somewhat misleading, as the “event-based” model corresponds to a continuous time overall (and reciprocally on a probabilistic perspective).";
    };
  };

  C14 = new(#96314a3d-e69d-4a17-aa1d-fce98843707e#, Reviewers.R1) {
    Text: Paragraph {
      "Overall, I wonder if the example of romance languages is adapted: complexity of the latin forms, addition of these empty characters that depends on the choice of the prior on H, interaction of sounds, multiplicity of the forms for a single meaning (e.g. ";
      "accusative/nominative, masculine/feminine), change of the meanings. In the results you observe that the deletion and insertion are more frequent than substitutions. ";
      "Doesn’t that mean that the model just favors insertion and deletion: if there are only half as much transitions, wouldn’t that just be a problem of prior? ";
      "The other possibility is that there are lots of insertion and deletion in your dataset overall. ";
      "Maybe the question should be the segmentation and the alignment themselves.";
    };
  };

  C15 = new(#8b3c2f1f-ceed-4964-a385-de75df4c3112#, Reviewers.R1) {
    Text: Paragraph {
      "In Fig 11 why is the alignment different depending on the models? ";
      "Is that because it is easier to align in some way if the rates are different between the classes (in particular deleting a /k/?).";
    };
  };

  C16 = new(#e1d990c4-c441-44b6-b224-51c376b3d2e2#, Reviewers.R1) {
    Text: Paragraph {
      "I would have liked to see some examples on simulated dataset, or even on another real family of languages (which is much more work so I understand to only focus on a single family).";
    };
  };

  C17 = new(#6e9118ce-df55-4efd-870e-18a41732f438#, Reviewers.R1) {
    Text: Paragraph {
      "P6 - Finally, the equilibrium frequencies reveal that Romance languages rely primarily on stops and short vowels for phonemic constrasts” I don’t understand how this relates with the previous sentence: these equilibrium frequencies mean that the stops are more frequent, not that they contrast more, or you need additional steps of thinking. ";
      "I don’t really know why those frequencies are interesting.";
    };
  };

  C18 = new(#282a37be-a39c-465a-b47d-83c21659b522#, Reviewers.R1) {
    Text: Paragraph {
      "I think the theoretical part on Bayesian is very accessible to the non-statisticians, which is a good point. I think more details should be added on the homology H: what is the prior chosen on it? ";
      "What is the exact procedure you use to compute its posterior distribution (I assume you integrate along the MCMC sample the posterior given the parameters, but it would be good to write it).";
    };
  };

  C19 = new(#d461c4c4-e6b1-4931-9ff3-febca0c96767#, Reviewers.R1) {
    Text: Paragraph {
      "The more I think about it the more I think the prior on H should depend on the value of λ and μ. ";
      "But in this case, why is it a marginal prior and not a prior given these parameters? ";
      "(p7 appendix) Please add some detail on that, as it might also explain why you observe more deletions and additions.";
    };
  };

  C20 = new(#c349a5f9-2263-4c11-8475-9fd5b938c92a#, Reviewers.R1) {
    Text: Paragraph {
      "The article by Lunter is quite difficult to read as it includes several elements linked with genetics, and I think some more details in supplement would be great.";
    };
  };

  C21 = new(#8c6f45b5-fdd1-4c93-be2c-f96a92e2b4a4#, Reviewers.R1) {
    Text: Paragraph {
      "The sentence “the likelihood accounts for all the histories of insertion, deletion, and segmental substitution that could have led to the observed words sampled from the nine languages” in 5.1 ";
      "is strange to that regards. ";
      "If it accounted for all the additions and deletion possible, I think the number of possible H 3 would be infinite, as the ancestral state can have any number of deleted characters. There is an approximation here somewhere (which is fine but would be interesting to understand exactly).";
    };
  };

  C22 = new(#3778b40f-c2c0-4d5d-9a98-fe1de03b9e2a#, Reviewers.R1) {
    Text: Paragraph {
      "I think the paper is interesting, but I have the impression that most of the choices are ad hoc: inserting the empty characters before the /a/ so that it can evolve into /ie/ in french really does not seem possible unless the people using the model have a thourough knwoledge of the history of the languages. It is my believe that comptuational methods in linguistics should be used to reduce human workload, and to get quantitative results. ";
      "On the second aspect the method proposed here is interesting, but I seriously doubt the possibility to apply it in less studied languages, where adding those empty characters would be criticable.";
    };
  };

  C23 = new(#dea1d699-0d2c-4f05-9a20-9e6d220f3414#, Reviewers.R1) {
    Text: Paragraph {
      "p7: lieasinabed, the whole list should go in appendix.";
    };
    AssignedTo(People.McCreight_Shawn);
    HasAnchor: true;
  };

  C24 = new(#237ad429-4fa2-4e55-8bb1-94fd1639f8c5#, Reviewers.R1) {
    Text: Paragraph {
      "Conclusion: estinmation";
    };
    AssignedTo(People.McCreight_Shawn);
    HasAnchor: true;
  };

  C25 = new(#11995460-7bae-4185-ba13-861d7c9130f6#, Reviewers.R1) {
    Text: Paragraph {
      "I don’t think Ψ is an amazing notation for a tree.";
    };
  };

  C26 = new(#5ce04d50-ce4a-4f51-9b28-0014edbbdc54#, Reviewers.R1) {
    Text: Paragraph {
      "Supplement p6: I would suggest introduce notations X for the observations and θ for the parameters. ";
      "That would make everything more readable. ";
      "Note that in your example, the tree topologies are not the parameters per se, they are the possible values of the parameter τ (same for ν). ";
      "The assumption λ < μ might be better as part of the prior distribution.";
    };
  };

  C27 = new(#8dcfb5bc-4e1e-411e-9981-3bd0e57b458e#, Reviewers.R1) {
    Text: Paragraph {
      "If you want a more accurate name for Metropolis-Hastings, you can use the full name Hastings-Metropolis-Rosenbluth-Teller (which has the advantage of giving back credit to the original authors).";
    };
  };

  C28 = new(#8fc83b55-a4bb-43c0-ade2-586266bd6ed6#, Reviewers.R1) {
    Text: Paragraph {
      "Appendix 1: You should precise “size of the 95% set ...” ";
      "why are some of the meanings given in english and other in english and latin?";
