  C35 = new(#a22ad687-3f7f-4d16-b0fe-1ab6c301527e#, Reviewers.R2) {
   Text: "\"study of (Moran et al. 2021, pp. 92-95)\"";
    AssignedTo(People.Goldstein_David);
