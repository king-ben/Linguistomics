using SegmentFeatures;
//======================================================================

readonly namespace<Segment> IPASegments {}

readonly namespace<SegmentPunctuation> IPASegments {
  GapSegment       = new("-", null, true);
  MissingSegment   = new("?", null, true);
  SylableBreak     = new(".");
  PrimaryStressAlt = new("'", "'");
  PrimaryStress    = new("ˈ", "'");
  SecondaryStress  = new("ˌ", "%");
}

