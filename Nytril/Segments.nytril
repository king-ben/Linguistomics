  VlPostalveolarFricative      = new("ʃʼ", Ejective Fricative, Places.PostAlveolar, "S_>");
  VlRetroflexFricativeEjective = new("ʂʼ", Ejective Fricative, Places.Retroflex, "s`_>");
  VlPalatalFricativeEjective   = new("ɕʼ", Ejective Fricative, Places.Palatal, "s\\_>");
  VlVelarFricativeEjective     = new("xʼ" , Ejective Fricative, Places.Velar, "x_>");
  VlUvularFricativeEjective    = new("χʼ", Ejective Fricative, Places.Uvular, "X_>");
  VlPostalveolarLatFric        = new("ɬʼ", Ejective Lateral Fricative, Places.Alveolar, "K_>");
  draised                      = new("d̥", Voiced Pulmonic Stop Occlusive Raised, Places.Alveolar);
}


