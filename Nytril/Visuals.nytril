SegmentOccuranceCaption(ExperimentData data) = Span {
  var l0 = data.Taxa[0].Language;

  "Comparison of segmental occurrence rates across languages. ";
  "Segments are ordered according to their frequency in "; l0; DotSpace;
  "For each language, bar heights are normalized to the most frequent segment in that language. ";
  "Languages are arranged by increasing Euclidean distance from "; l0; " (indicated by the red line). ";
};

class SegmentOccuranceFigure: ExperimentContent {
  Constructor(ExperimentData data) {
    super.Constructor(data, "Segment Occurrence Rates");
    Data = data;
  }

  override GetCaption(ContentStyle style) = SegmentOccuranceCaption(Data);

  override GetBody(ContentStyle style) = new SegmentFrequencyChart(Data, false).ShowChart(style);
}

