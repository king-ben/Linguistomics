using Format, EquationSymbols, References;

//======================================================================

abstract class QRatesBase: Content {
  const int TopCount = 15;

  var AlignedCountClass QRates;

  Constructor(name, AlignedCountClass qrates) {
    super.Constructor(name);
    QRates = qrates;
  }

  static TransitionTitle(type) = "The top {0} {1} transitions"(TopCount, type);
}

//======================================================================

class AverageAllFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor("All Rates", qrates);
  }

  override GetBody(ContentStyle style) = QRates.ShowAllRates;
}

//======================================================================

class AverageSortedFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor("Rate vs. Direction", qrates);
  }

  override GetBody(ContentStyle style) = VBox {
    Chart(100%, Math.Min(6", ExtentHeight - 48pt)) {
      TipNoPublish: true;
      ChartType: ChartTypes.Scatter;
      TextHeight: 12pt;

      XLabel: RateDescriptor(Lang.RateFactor);

      ValueLabel: PaperStyle.ValueLabel {
        RateDescriptor("Direction");
      };

      ChartSeries {
        TextHeight: 6pt;
        Marker: Markers.Dot;
        foreach (var si in QRates.LegendSegments) {
          foreach (var sj in QRates.LegendSegments) {
            if (si.Index < sj.Index) {
              var a = QRates.RateMatrix[si.Index, sj.Index];
              new DataPoint(a.Rate, a.Direction) {
                Reference: a;
                Marker: Canvas(4pt, 4pt) {
                  HAlign: Center;
                  VAlign: Center;
                  Background: a.S0.Partition.BackColor;
                  BorderRadius: 2pt;
                  a.S1.Partition.Marker;
                };
              };
            }
          }
        }
      };
    };

    Separation: 20pt;
    Canvas(ExtentWidth) {
      HAlign: Center;
      QRates.Rule.ShowBlockLegend(QRates.Partitions, 10pt);
    }
  };

}

//======================================================================

class RateDirectionFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor("Directionality", qrates);
  }

  override GetBody(ContentStyle style) = QRates.ShowDirection;
}

//======================================================================

class QRatesMatrixFigure: QRatesBase {
  Constructor(AlignedCountClass qrates, name = null) {
    super.Constructor(name ?? Span {"Rate Matrix "; RateMatrix}, qrates);
  }

  override GetBody(ContentStyle style) = QRates.PartitionBox(style, ExtentSize);
}

//======================================================================

class QRatesDiagonalFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor("Rate of segmental change", qrates);
  }

  override GetCaption(ContentStyle style) = Span {
    "The rate of change when in a particular segmental state (or "; -qii; ")";
  };

  override GetBody(ContentStyle style) = new DiagonalClass(QRates.Rule, QRates).Display(style);
}

//======================================================================

class SpecificRatesFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor("Specific Rates", qrates);
  }

  static bool Predicate(SegmentRate a) = a.IsPair("p", "f") or a.IsPair("s", "h") or a.IsPair("k", "ʧ");

  override GetBody(ContentStyle style) = QRates.Pairs(-1, @Predicate);
}

//======================================================================

class QRatesTopFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor(TransitionTitle("segmental"), qrates);
  }

  override GetBody(ContentStyle style) = QRates.Extrema(TopCount, true);
}

//======================================================================

class QRatesCCFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor(TransitionTitle("Consonant-Consonant"), qrates);
  }

  static bool Predicate(SegmentRate a) = a.F0.HasFlagMask(SegmentFeatures.Vowel, SegmentFeatures.NoFeature) and
                                         a.F1.HasFlagMask(SegmentFeatures.Vowel, SegmentFeatures.NoFeature);

  override GetBody(ContentStyle style) = QRates.Pairs(TopCount, @Predicate);
}

//======================================================================

class QRatesOneWayFigure: QRatesBase {
  Constructor(AlignedCountClass qrates) {
    super.Constructor(TransitionTitle("highly directed"), qrates);
  }

  override GetBody(ContentStyle style) = QRates.ShowChartPairs(TopCount, QRates.SortByDirection);
}

