using Format, Units, IO;

//======================================================================

class SearchDataClass: Fact {
  field string WordsContaining;

  Constructor {
    super.Constructor(#2298c73f-87fb-4b36-92de-0c3582b94f6c#);
    ReadFromStorage;
  }
}

//======================================================================

class WordsContainingClass: Action {
  var SearchDataClass Data;

  Constructor(SearchDataClass data) {
    super.Constructor(Actions.RunQuery);
    Data = data;
  }

  override GetQuery {
    if (Data.WordsContaining is valid) {
      return MatchAny(WordClass) {
        MatchAny(Segment) {
          Ipa: Data.WordsContaining;
        };
      };
    }

    return null;
  }
}

//======================================================================

class DiagnosticsViewClass: DocumentClass {
  var DataSetClass        Data;
  var ContentStyle   Style;
  var SegmentDisplayClass Display;
  var SearchDataClass     SearchData;

  Constructor(ContentStyle style, DataSetClass data) {
    super.Constructor(#ded5b32d-f925-4ca0-b6b6-cfec8100fd42#, "Diagnostics");
    Description = "Summary of the data used in the experiment with diagnostic views";
    Data        = data;
    Display     = new(data);
    SearchData  = new;
    Style       = style;
  }

  ShowSegmentTables = Block {
    SegmentSetClass set = new(512);
    MatchingVowels.ShowTable(Style, Display.DisplaySegments, set);
    MatchingConsonants.PulmonicTable.ShowTable(Style, Data, set);
    MatchingConsonants.NonPulmonicTable.ShowTable(Style, Data, set);
    MatchingConsonants.PulmonicAffricatesTable.ShowTable(Style, Data, set);
    MatchingConsonants.EjectiveAffricatesTable.ShowTable(Style, Data, set);
    MatchingOther.ShowTable(Display.DisplaySegments, set);
  };

  ShowQuery = Block {
    TextHeight: 14pt;

    Paragraph {
      HBox {
        TextControl(new(ref SearchData.WordsContaining), 1 inches, null, new Edge(1, 2)) {
          "Find Words Containing";
          Action: Actions.Refresh;
        };

        ButtonControl(null, null, PadAll(2)) {
          BorderRadius: 3;
          Action: new WordsContainingClass(SearchData);
          TextColor: Colors.Green;
          Icons.search;
        };
      }
    };
  };

  override GetDocument = Document(new(0.5 inches, 0.75 inches, 0.5 inches, 0.5 inches)) {
//    if (not System.IsPublishing)
//      ShowQuery;

    TextHeight: 9pt;

    Content[] content = [
      new PriorTreeClass(Data),
      new AppendixClass(Lang.UniqueSegments, Display.IPASegmentTable),
      new SegmentAssignmentsClass(Data),
      new SegmentTransitionClass(Data),
      new AppendixClass("Words containing each segment", Display.ShowWordsForEachSegment),
      new AppendixClass("Word Lists by Language", DisplayWords.ShowWordsByLanguage(Style, Data)),
      new AppendixClass("Segment Groups", ShowSegmentTables),
      new AppendixClass(Lang.ConceptsUsed, AllWords.ShowTable(Style, Data, 10pt)),
      new AppendixClass(Lang.Languages, Display.ShowLanguageDetails(Style)),
//      new("Euler Feature Diagram", new EulerDiagramClass().FeatureChart(Data)),
    ];

    if (Data.RawData) {
      content += [
        new FrequencyFigureClass(new SegmentFrequencyClass(Data, false), "Segment Frequency"),
        new FrequencyFigureClass(new SegmentFrequencyClass(Data, true), "Segment Frequency by Partition"),
        new FrequencyFigureClass(new PartitionFrequencyClass(Data), "Partition Frequency"),
        new AppendixClass(Lang.Diacritics, MatchingDiacritics.ShowTable),
        new CognateCoverageClass(Data),
        new ConceptGroupsClass(Data)
      ];
    }

    foreach (var c in content) {
      Style.Heading1 {
        PageBreakBefore: true;
        c.Title;
      };

      var caption = c.GetCaption(Style);
      if (caption is not null) {
        Style.AppendixCaption {
          caption;
        };
      }

      c.GetBody(Style, null);
    }

    PageBreak;

    Paragraph {
      ParAlignment: Center;
      "Chang A3";
    };
    Tree(100%, null) {
      Default: new Node(null) {
        Curvature: 10%;
        Bevel: 10%;
      };
      TextHeight: 5.5pt;
      Root: LanguageBranches.ChangA3;
    }
  };
}

//======================================================================

class ConceptGroupsClass: DataContentClass {
  Constructor(DataSetClass data) {
    super.Constructor(data, "Concept Groups");
  }

  override GetBody(ContentStyle style, title) = Block {
    var concepts = Data.UsedConcepts.ToSortedArray();
    WordGroups[] groups = WordGroups.ValueArray[1..];
    Table(PaperStyle.TableBorder, PadLR(3pt), [Column.Fit(2 inches)]) {
      Row {
        PaperStyle.HeaderCell(style);
        PaperStyle.HeaderCell(style) {
          Lang.Concept;
        };
        PaperStyle.HeaderCell(style) {
          "Type";
        };
        foreach (var g in groups) {
          PaperStyle.HeaderCell(style) {
            g.Name;
          };
        }
      };
      foreach (var concept in concepts) {
        PaperStyle.RowBar(each0) {
          each1;
          concept.GetTitle;
          concept.WordType.Name;
          foreach (var g in groups) {
            Cell {
              HAlign: Center;
              if (concept.WordGroup.HasFlag(g))
                Tex.bullet;
            }
          }
        }
      }
    }
  };
}

//======================================================================

class PriorTreeClass: DataContentClass {
  Constructor(DataSetClass data) {
    super.Constructor(data, "Prior Trees");
  }

  override GetBody(ContentStyle style, title) = Block {
    Paragraph {
      foreach (var tree in TreeExamples.PriorTrees)
        PaperStyle.ShowTree(style, tree, 30%, Lang.Tree+each1);
    };
  };
}

//======================================================================

class CognateCoverageClass: DataContentClass {
  Constructor(DataSetClass data) {
    super.Constructor(data, "Cognate Coverage");
  }

  override GetBody(ContentStyle style, title) = Block {
    style.Heading1 {
      "By Language";
    };

    Chart(100%, 3") {
      ChartType: ChartTypes.Column;
      TextHeight: 10pt;
      ValueLabel: "%";

      XAxis: ChartAxis {
        (each Data.Taxa).Language;
      };
      ValueAxis: ChartAxis;

      ChartSeries {
        foreach (var t in Data.Taxa)
          Data.Coverage(t) * 100.0;
      };
    };
    Paragraph;


    style.Heading1 {
      "By Number of Languages";
    };

    var count = new Vector<int>(Data.Taxa.Length+1, 0.0);
    foreach (var c in Data.UsedCognates) {
      var used = 0;
      foreach (var word in c.Words) {
        if (word is valid and word.Text is valid)
          ++used;
      }
      ++count[used];
    }

    Chart(100%, 3") {
      ChartType: ChartTypes.Column;
      TextHeight: 10pt;

      ValueLabel: PaperStyle.ValueLabel {
        Lang.Cognates;
      };
      ValueAxis: ChartAxis;

      XAxis: ChartAxis {
        0..<count.Length step 1;
      };
      XLabel: "Languages Included";

      ChartSeries {
        count.ToArray;
      };
    };
  };
}

//======================================================================

class AppendixClass: Content {
  var Body;

  Constructor(title, body) {
    super.Constructor(title);
    Body = body;
  }

  override GetBody(ContentStyle style, title) = Body;
}

