class ConfigurationDocument: DocumentEntry {
  var ExperimentData Data;
  var TreeSet        TreeSet;

  Constructor(ExperimentData data, TreeSet treeset) {
    super.Constructor(#7fc3842e-41d2-4b65-bcd0-be2fd9ede5b2#, "Configuration File");
    Data    = data;
    TreeSet = treeset;
  }

  override GetDocument = Document {
    new ConfigFileClass(Data, TreeSet.Models[0].Run[0], TreeSet.Tree).Show;
  };
}

//======================================================================

class WordDocument: DocumentEntry {
  var ExperimentData     Data;
  var SegmentPartition[] Partitions;

  Constructor(ExperimentData data, SegmentPartition[] partitions) {
    super.Constructor(#a12b9731-b78e-49e1-986f-a72af5d1ec25#, "Word File");
    Data       = data;
    Partitions = partitions;
  }

  ShowUniqueSegments = Span {
    PaperStyle.ReadOnly; PaperStyle.Variable("Segments"); " = [";
    Span {
      Separator: CommaSpace;
      ShowString(each ((each Data.UniqueSegments).Ipa));
    };
    "];";
  };

  ShowLanguages = TextBlock {
    Span {PaperStyle.ReadOnly; PaperStyle.Variable("LanguageSet"); " = [";};
    TextBlock {
      IndentSpace: 2;

      foreach (var l in Data.LanguageSet) {
        Span {
          PaperStyle.Variable("Languages");
          Dot;
          PaperStyle.Variable(l.Name);
          if (each1 < Data.LanguageSet.Length)
            CommaSpace;
        }
      }
    };
    "];";
  };

  ShowSegmentIndices(SegmentPart[] segments) = Span {
    "[";
    Span {
      Separator: CommaSpace;
      (each segments).Index;
    };
    "]";
  };

  ShowPartitions = TextBlock {
    Span {
      PaperStyle.ReadOnly; PaperStyle.Variable(nameof(PartitionInfo)); "[] "; PaperStyle.Variable("Partitions"); " = [";
    };

    foreach (var p in Partitions) {
      TextBlock {
        Span {
          "  "; PaperStyle.Keyword("new"); "(";
          ShowString(p.Name);
          ", ";
          ShowSegmentIndices(p.Segments);
          "),"
        }
      };
    }
    "];";
  };

  ShowVar(name, value) = Span {
    PaperStyle.Variable(name); " = "; value; ";";
  };

  ShowVariables = TextBlock {
    PaperStyle.NameSpace("Info");
    TextBlock {
      IndentSpace: 2;
      ShowVar("WordCutoff", Data.WordCutoff);
    };
    "}";
  };

  override GetDocument = Document {
    TextHeight: 9pt;

    TextBlock {
      Span {
        PaperStyle.Keyword("using ");
        "Format, WordGroups;";
      };
      Empty;
      ShowVariables;
      Empty;

      ShowUniqueSegments;
      Empty;
      ShowLanguages;
      Empty;
      ShowPartitions;
      Empty;

      PaperStyle.NameSpace("Concepts");
      Empty;

      foreach (var cognate in Data.UsedCognates) {
        var concept = cognate.Concept;
        var lvector = new Vector<CognateWord>(Data.LanguageSet.Length, null);

        foreach (var word in cognate.Words) {
          if (word.Aligned is valid)
            lvector[word.Language.LangIndex] = word;
        }

        Span {
          PaperStyle.Variable(concept.Name);
          Dot;
          PaperStyle.Variable(cognate.Name);
          " = [";
        };

        TextBlock {
          IndentSpace: 2;
          foreach (var word in lvector) {
            Span {
              if (word is valid)
                ShowSegmentIndices(word.Aligned);
              else
                PaperStyle.Keyword("null");
              Comma;
            }
          }
        };

        "];";
      }

      Empty;
      "}";
    };
  };
}

//======================================================================

class SegmentTransitionFigure: Content {
  var ExperimentData Data;

  Constructor(ExperimentData data) {
    super.Constructor("Prior Segment Transition Counts");
    Data = data;
  }

  override GetCaption(ContentStyle style) = Span {
    "The number of times that a segment on the left vertical bar differs from any other other segment at the same position. The rates of transitions to and from gaps are ignored. Partitions are ordered by frequency of occurrance. Transition counts are shown in a scaled color box. The chart has diagonal symmetry.";
  };

  override GetBody(ContentStyle style, title) = new PriorCount(Data).PartitionBox(style, new (ExtentWidth, ExtentHeight - 1.6"));
}

