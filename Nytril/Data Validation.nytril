using Format;

//======================================================================

class SearchWordInfo: Fact {
  field string WordsContaining;

  Constructor {
    super.Constructor(#2298c73f-87fb-4b36-92de-0c3582b94f6c#);
    ReadFromStorage;
  }
}

//======================================================================

class WordsSearchAction: Action {
  var SearchWordInfo Data;

  Constructor(SearchWordInfo data) {
    super.Constructor(Actions.RunQuery);
    Data = data;
  }

  override GetQuery {
    if (Data.WordsContaining is valid) {
      return MatchAny(CognateWord) {
        MatchAny(VocalSegment) {
          Ipa: Data.WordsContaining;
        };
      };
    }

    return null;
  }
}

//======================================================================

class DiagnosticGraphSection: Content {
  var ExperimentData Data;

  Constructor(ExperimentData data) {
    super.Constructor("");
    Data = data;
  }

  AddGraph(ContentStyle style, title, fact, int depth=1) = Block {
    style.Heading2 {
      title;
    };
    var graph = new Graph();
    graph.AddNodes(fact, depth);
    graph;
  };

  override GetBody(ContentStyle style, title) = Block {
    AddGraph(style, "Partitions", Data.Rule.Partitions);
    AddGraph(style, "Segment Property", VocalSegment.Features.Diphthong);
    AddGraph(style, "Segment", VocalSegments.au);
    var l = Data.LanguageSet[0];
    AddGraph(style, l.Name, l);
  };
}

//======================================================================

class DiagnosticsDocument: DocumentEntry {
  var ExperimentData Data;
  var ContentStyle   Style;
  var SegmentDisplay Display;
  var SearchWordInfo Search;

  Constructor(ContentStyle style, ExperimentData data) {
    super.Constructor(#ded5b32d-f925-4ca0-b6b6-cfec8100fd42#, "Diagnostics");
    Description = "Summary of the data used in the experiment with diagnostic views";
    Data        = data;
    Display     = new(data);
    Search      = new;
    Style       = style;
  }

  ShowSegmentTables = Block {
    SegmentSet set = new(512);
    MatchingVowels.ShowTable(Style, Display.DisplaySegments, set);
    MatchingConsonants.PulmonicTable.ShowTable(Style, Data, set);
    MatchingConsonants.NonPulmonicTable.ShowTable(Style, Data, set);
    MatchingConsonants.PulmonicAffricatesTable.ShowTable(Style, Data, set);
    MatchingConsonants.EjectiveAffricatesTable.ShowTable(Style, Data, set);
    MatchingOther.ShowTable(Display.DisplaySegments, set);
  };

  ShowQuery = Block {
    TextHeight: 14pt;

    Paragraph {
      HBox {
        TextControl(new(ref Search.WordsContaining), 1", null, new Edge(1, 2)) {
          "Find Words Containing";
          Action: Actions.Refresh;
        };

        ButtonControl(null, null, PadAll(2)) {
          BorderRadius: 3;
          Action: new WordsSearchAction(Search);
          TextColor: Colors.Green;
          Icons.search;
        };
      }
    };
  };

  override GetDocument = Document(new(0.5", 0.75", 0.5", 0.5")) {
//    if (not System.IsPublishing)
//      ShowQuery;

    TextHeight: 9pt;

    Content[] content = [
      new PriorTreeFigure(Data),
      new DiagnosticGraphSection(Data),
      new AppendixContent(Lang.UniqueSegments, Display.VocalSegmentTable),
      new SegmentAssignmentsFigure(Data),
      new SegmentTransitionFigure(Data),
      new AppendixContent("Words containing each segment", Display.ShowWordsForEachSegment),
      new AppendixContent("Word Lists by Language", DisplayWords.ShowWordsByLanguage(Style, Data)),
      new AppendixContent("Segment Groups", ShowSegmentTables),
      new AppendixContent(Lang.ConceptsUsed, AllWords.ShowTable(Style, Data, 10pt)),
      new AppendixContent(Lang.Languages, Display.ShowLanguageDetails(Style)),
//      new("Euler Feature Diagram", new EulerDiagramClass().FeatureChart(Data)),
    ];

    if (Data.RawData) {
      content += [
        new FrequencyFigure(new SegmentFrequencyChart(Data, false), "Segment Frequency"),
        new FrequencyFigure(new SegmentFrequencyChart(Data, true), "Segment Frequency by Partition"),
        new FrequencyFigure(new PartitionFrequencyChart(Data), "Partition Frequency"),
        new AppendixContent(Lang.Diacritics, MatchingDiacritics.ShowTable),
        new CognateCoverage(Data),
        new ConceptGroupsFigure(Data)
      ];
    }

    foreach (var c in content) {
      Style.Heading1 {
        PageBreakBefore: true;
        c.Title;
      };

      var caption = c.GetCaption(Style);
      if (caption is not null) {
        Style.AppendixCaption {
          caption;
        };
      }

      c.GetBody(Style, null);
    }

    PageBreak;

    Paragraph {
      ParAlignment: Center;
      "Chang A3";
    };
    TreeBox(100%, null) {
      Default: new Node(null) {
        Curvature: 10%;
        Bevel: 10%;
      };
      TextHeight: 5.5pt;
      Root: LanguageBranches.ChangA3;
    }
  };
}

//======================================================================

class ConceptGroupsFigure: ExperimentContent {
  Constructor(ExperimentData data) {
    super.Constructor(data, "Concept Groups");
  }

  override GetBody(ContentStyle style, title) = Block {
    var concepts = Data.UsedConcepts.ToSortedArray();
    WordGroups[] groups = WordGroups.ValueArray[1..];
    Table(PaperStyle.TableBorder, PadLR(3pt), [Column.Fit(2")]) {
      Row {
        PaperStyle.HeaderCell(style);
        PaperStyle.HeaderCell(style) {
          Lang.Concept;
        };
        PaperStyle.HeaderCell(style) {
          "Type";
        };
        foreach (var g in groups) {
          PaperStyle.HeaderCell(style) {
            g.Name;
          };
        }
      };
      foreach (var concept in concepts) {
        PaperStyle.RowBar(each0) {
          each1;
          concept.GetTitle;
          concept.WordType.Name;
          foreach (var g in groups) {
            Cell {
              HAlign: Center;
              if (concept.WordGroup.HasFlag(g))
                Tex.bullet;
            }
          }
        }
      }
    }
  };
}

//======================================================================

class PriorTreeFigure: ExperimentContent {
  Constructor(ExperimentData data) {
    super.Constructor(data, "Prior Trees");
  }

  override GetBody(ContentStyle style, title) = Block {
    Paragraph {
      foreach (var tree in TreeExamples.PriorTrees)
        PaperStyle.ShowTree(style, tree, 30%, Lang.Tree+each1);
    };
  };
}

//======================================================================

class CognateCoverage: ExperimentContent {
  Constructor(ExperimentData data) {
    super.Constructor(data, "Cognate Coverage");
  }

  override GetBody(ContentStyle style, title) = Block {
    style.Heading1 {
      "By Language";
    };

    Chart(100%, 3") {
      ChartType: ChartTypes.Column;
      TextHeight: 10pt;
      ValueLabel: "%";

      XAxis: ChartAxis {
        (each Data.Taxa).Language;
      };
      ValueAxis: ChartAxis;

      ChartSeries {
        foreach (var t in Data.Taxa)
          Data.Coverage(t) * 100.0;
      };
    };
    Paragraph;


    style.Heading1 {
      "By Number of Languages";
    };

    var count = new Vector<int>(Data.Taxa.Length+1, 0.0);
    foreach (var c in Data.UsedCognates) {
      var used = 0;
      foreach (var word in c.Words) {
        if (word is valid and word.Text is valid)
          ++used;
      }
      ++count[used];
    }

    Chart(100%, 3") {
      ChartType: ChartTypes.Column;
      TextHeight: 10pt;

      ValueLabel: PaperStyle.ValueLabel {
        Lang.Cognates;
      };
      ValueAxis: ChartAxis;

      XAxis: ChartAxis {
        0..<count.Length step 1;
      };
      XLabel: "Languages Included";

      ChartSeries {
        count.ToArray;
      };
    };
  };
}

//======================================================================

class AppendixContent: Content {
  var Body;

  Constructor(title, body) {
    super.Constructor(title);
    Body = body;
  }

  override GetBody(ContentStyle style, title) = Body;
}

