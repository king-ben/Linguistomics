using Format;

typedef StatArray StatClass[];
typedef StatMat   StatClass[][];

//======================================================================

class CognateId {
  var Concept,
      Cognate,
      Count,
      Blocks;

  Constructor(concept, cognate, count, blocks) {
    Concept = concept;
    Cognate = cognate ?? DefaultCognate;
    Count   = count;
    Blocks  = blocks;
  }

  AlignIndexClass FindAlignment(RunResultsThread run) {
    foreach (var a in run.Alignments) {
      if (a.ConceptName == Concept and a.CognateName == Cognate)
        return a;
    }
    return null;
  }
}

//======================================================================

class StatClass {
  var Lower,
      Mean,
      Upper;

  Constructor(lower, mean, upper) {
    Lower = lower;
    Mean  = mean;
    Upper = upper;
  }

  ShowRight(number) = HBox {
    Space*2;
    TextHeight: 80%;
    TextColor: Colors.Gray;
    number;
  };

  ShowBox = VBox {
    HAlign: Center;
    TextDigits: 3;
    TextSignificant: true;
    ShowRight(Upper);
    Mean;
    ShowRight(Lower);
  };

  override GetLayoutTip = ShowBox;
}

//======================================================================

class RunResultsThread: Parallel.Thread {
  var ExperimentData     Data;
  var ExperimentRun      Run;
  var StatMat            NCQRates,
                         TransitionStats;
  var StatArray          NCQFreqs;
  var AlignedCountClass  QRates;
  var AlignIndexClass[]  Alignments;
  var double             InsertionRate,
                         InsertionRateLow,
                         InsertionRateHigh,
                         DeletionRate,
                         DeletionRateLow,
                         DeletionRateHigh;
  var double[]           EquilibriumFrequencies;
  var bool               Complete;
  var                    GapSpectrum,
                         AlignmentFile;

  Constructor(ExperimentData data, ExperimentRun run) {
    super.Constructor;
    Run           = run;
    Data          = data;
    AlignmentFile = Info.ExperimentRoot run.RootFolder Info.AlignmentFile;
  }

  static int CompareAlignment(AlignIndexClass a0, AlignIndexClass a1) {
    var c = a0.Alignments.Length.Compare(a1.Alignments.Length);
    if (c == 0)
      return a0.ConceptName.Compare(a1.ConceptName);
    return c;
  }

  double TestStatistic {
    var   spectrum = GapSpectrum;
    double n       = 0;
    double lnL1    = 0.0;
    double lnL0    = 0.0;

    Vector<double> statistic = new(spectrum.Length, 0.0);
    Vector<double> countVals = new(spectrum[0].Length, 0.0);
    foreach (var gap in spectrum) {
      var ni = Math.Sum(gap);
      n += ni;
      foreach (var value in gap) {
        if (value != 0)
          lnL1 += value * Math.Log(value / ni);
      }
      statistic[each0] = n;
      foreach (var value in gap)
        countVals[each0] += value;
    }

    foreach (var value in countVals) {
      if (value != 0)
        lnL0 += value * Math.Log(value/n);
    }
    return -2.0 * (lnL0 - lnL1);
  }

  override bool Execute {
    var align    = IO.ReadScript(AlignmentFile).Root;
    var treefile = Info.ExperimentRoot Run.RootFolder Info.TreeFile;
    if (IO.FileExists(treefile)) {
      Run.ResultTree = IO.ReadTree(treefile, attribute LanguageNode);

      var qrates = align.?QRates;
      if (Run.ResultTree is valid and qrates is valid) {
        QRates                 = new(this, qrates, false);
        NCQFreqs               = align.?NCQFreqs as StatArray;
        TransitionStats        = align.?TransitionStats as StatMat;
        NCQRates               = align.?NCQRates as StatMat;
        EquilibriumFrequencies = align.?EquilibriumFrequencies as double[];
        InsertionRate          = align.?InsertionRateMean;
        InsertionRateLow       = align.?InsertionRateLow;
        InsertionRateHigh      = align.?InsertionRateHigh;
        DeletionRate           = align.?DeletionRateMean;
        DeletionRateLow        = align.?DeletionRateLow;
        DeletionRateHigh       = align.?DeletionRateHigh;
        GapSpectrum            = align.?GapSpectrum;

        var alignments = new List<AlignIndexClass>(1024);
        foreach (var a in align.Alignments) {
          foreach (var c in Data.UsedCognates) {
            if (c.Concept.Name == a.ConceptName and c.Name == a.CognateName) {
              a.Cognate = c;
              alignments.Add(a);
              break;
            }
          }
        }
        Alignments = alignments.ToSortedArray(false, @CompareAlignment);
        return true;
      }
    }
    return false;
  }
}

//======================================================================

class AlignmentChart {
  var ExperimentData   Data;
  var RunResultsThread Run;

 Constructor(ExperimentData data, RunResultsThread run) {
    Data = data;
    Run  = run;
  }

  ShowChart(ContentStyle style, Size size) = VBox(size.Width, size.Height, 0.5) {
    style.SansSerif;
    // Try to make proportional squares
    var xitems = size.Width / 130 as int;
    var yitems = Math.Floor((Run.Alignments.Length + xitems - 1) / xitems);
    var bsize  = new Size(size.Width / xitems, size.Height / yitems);
    AlignIndexClass[][] rows = Run.Alignments / xitems;

    TextHeight: Math.Min(8pt, bsize.Height - 3.2pt);

    foreach (var row in rows) {
      HBox(null, bsize.Height, BorderB(new Edge(0.25pt, 1, 90%))) {
        VAlign: Center;
        foreach (var a in row) {
          VBox(bsize.Width, null) {
            HAlign: Center;

            var ap = new AlignPairClass(Data, a);
            Paragraph {
              Span {
                ap.TableName;
                TipAction: ap;
              };
            };
            Paragraph {
              TextHeight: 10pt;
              TextColor: Colors.LightGray;
              a.TotalCount;
            };
          }
        }
      }
    }
  };

  ShowAll = Block {
    foreach (var a in Run.Alignments) {
      new AlignPairClass(Data, a).ShowAll;
      Paragraph(BorderT(1));
    }
  };

  ShowSet(CognateId[] examples, bool label) = Table(null, null, label ? [0.75", Column.Expand] : [Column.Expand]) {
    foreach (var e in examples) {
      var found = e.FindAlignment(Run);
      if (found is valid) {
        var ap = new AlignPairClass(Data, found);
        Row {
          if (label) {
            Cell(PadR(10pt)) {
              VAlign: Center;
              e.Concept;
              e.Cognate Italic;
            };
          }
          ap.ShowFigureDetails(Data, e.Count, e.Blocks);
        };
      }
      else
        System.Assert(false, "Concept {0} not found"(e.Concept));
    }
  };
}

//======================================================================

class RateTransition {
  var                   MaxRate,
                        MaxFrequency;
  var Matrix<StatClass> Rates;
  var PartitionRule     Rule;

  Constructor(RunResultsThread run, PartitionRule rule) {
    Rule = rule;
    var stats = run.TransitionStats;
    var count = stats.Length;
    Rates = new(count, count, null);

    var max = 0.0;
    for (int i = 0; i < count; ++i) {
      for (int j = 0; j < count; ++j) {
        var c = stats[i, j];
        var f = c?.Upper ?? 0.0;
        if (f > max)
          max = f;
        Rates[i, j] = c;
      }
    }
    MaxRate      = max;
    MaxFrequency = 1.0;
  }
}

//======================================================================

class SegmentRate: Action {
  var AlignedCountClass Count;
  var RunResultsThread  Results;
  var ExperimentData    Data;
  var SegmentPart       S0,
                        S1;
  var SegmentFeatures   F0,
                        F1;
  var                   Original,
                        Rate,
                        Reverse,
                        Direction;
  var bool              Diagonal,
                        Symmetric;

  Constructor(RunResultsThread results, AlignedCountClass count, SegmentPart s0, SegmentPart s1, rate, reverse, bool symmetric, bool diagonal) {
    super.Constructor(Actions.ToDocument, null, Guid.FromHash("Rate"+s0.Ipa + s1.Ipa));

    Results   = results;
    Data      = results.Data;
    Count     = count;
    S0        = s0;
    S1        = s1;
    F0        = s0.Features;
    F1        = s1.Features;
    Original  = rate;
    Rate      = GetLogRate(rate);
    Reverse   = GetLogRate(reverse);
    Direction = Rate - Reverse;
    Symmetric = symmetric;
    Diagonal  = diagonal;
  }

  static int CompareRate(SegmentRate a0, SegmentRate a1) = a0.Rate.Compare(a1.Rate);

  static int CompareDirection(SegmentRate a0, SegmentRate a1) = a0.Direction.Compare(a1.Direction);

  static bool SortDescending = true;

  static GetLogRate(r) {
    if (r < 0)
      return Math.Min(0, -11 - Math.Log(-r, 10));
    else if (r > 0)
      return Math.Max(0, 11 + Math.Log(r, 10));
    return 0;
  }

  bool IsPair(ipa0, ipa1) {
    return S0.Segment.Ipa == ipa0 and S1.Segment.Ipa == ipa1;
  }

  double DirectionHeat = 1.0 - 0.5 * Direction * Count.DirFactor;

  ShowPartition(SegmentPart s, textheight) = Canvas(textheight * 2.5) {
    BorderRadius: PaperStyle.BorderSize;
    HAlign: Center;
    Background: s.Partition.BackColor;
    TextColor: s.Partition.TextColor;
    s.ShowSegment;
  };

  ShowBox(textheight) = HBox {
    TextHeight: textheight;
    Separation: textheight * 0.25;
    VAlign: Center;
    Tip: this;

    ShowPartition(S0, textheight);
    Span {
      TipAction: this;
      Symmetric ? Tex.leftrightarrow : Tex.rightarrow;
    };
    ShowPartition(S1, textheight);
  };

  override GetLayoutSpan = ShowBox(11pt);

  private ShowNumber(name, number) = Paragraph {
    name;
    ": ";
    Span {
      TextDigits: 5;
      number;
    };
  };

  GetExamples(th, int max) = Block {
    TextHeight: th;
    ShowBox(th);
    Paragraph {
//      "Value: ";
      TextScientific: true;
      TextDigits: 2;
      Original;
    };

/*
    ShowNumber(RateDescriptor(Lang.RateFactor), Rate);
    if (!Symmetric) {
      ShowNumber(RateDescriptor("Reverse Factor"), Reverse);
      Span {
        var c = PaperStyle.HeatMap.InterpolateColor(DirectionHeat);
        TextBackground: c;
        TextColor: c.TextCompliment;
        ShowNumber(RateDescriptor("Direction"), Direction);
      }
    }
*/
    var sorted = GetList;
    max = Math.Min(sorted.Length, max);
    if (sorted is valid) {
      Paragraph {
        TextHeight: 12pt;
        SpaceBefore: 6pt;
        "Examples:";
      };

      Paragraph {
        Separator: Space;
        for (var i = 0; i < max; ++i) {
          var s = sorted[i];
          new AlignPairClass(Data, s.Congate).ShowFigureData(s.Congate, s.Data);
        }
      };
    }
  };

  override GetLayoutTip = GetExamples(24pt, 10);

  override GetDocument = GetExamples(14pt, 100);

  static int CompareProb(AlignSort s1, AlignSort s2) = s1.Data.Prob.Compare(s2.Data.Prob);

  List<AlignSort> GetList {
    // Find cognate sets that have the first segment in one language and the second in another language

    var i0   = S0.Index;
    var i1   = S1.Index;
    var list = new List<AlignSort>(1024);

    foreach (var cognate in Results.Alignments) {
      AlignData found = null;

      foreach (var alignment in cognate.Alignments) {
        foreach (var w1 in alignment.WordSet) {
          foreach (var seg in w1) {
            if (seg == i0) {
              var ni = each0;
              foreach (var w2 in alignment.WordSet) {
                if (w2[ni] == i1) {
                  found = alignment;
                  break;
                }
              }
            }
            if (found is valid)
              break;
          }
          if (found is valid)
            break;
        }
        if (found is valid)
          break;
      }

      if (found is valid)
        list.Add(new(found, cognate));
    }
    list.Sort(true, @CompareProb);
    return list;
  }
}

