class SegDataClass {
  var SegmentRate Rate;
  var double      Value;

  Constructor(SegmentRate rate) {
    Rate  = rate;
    Value = -rate.Original;
  }

  override GetLayoutTip = VBox(PaperStyle.SegmentWidth) {
    HAlign: Center;

    Span {
      TextBackground: Rate.S0.Partition.BackColor;
      Rate.S0.Partition.Name;
    };
    Span {
      "Value"; ColonSpace;
      Value;
    };
    if (not Rate.Diagonal) {
      Span {
        Lang.RateFactor; ColonSpace;
        TextDigits: 2;
        Rate.Rate;
      };
    }

    Rate.S0.GetLayoutTip;
  };
}

//======================================================================

class AlignedCountClass: CountBase {
  delegate bool FindRateDelegate(SegmentRate r);

  var RunResultsThread    Results;
  var List<SegmentRate>   RateList;
  var Matrix<SegmentRate> RateMatrix;
  var PartitionRule       Rule;
  var SegmentPartition[]  Partitions;
  var SegmentRate[]       SortedRates,
                          SortByDirection;
  var double              DiagFactor,
                          RateFactor,
                          DirFactor;
  var bool                Symmetric;

  Constructor(RunResultsThread results, rates, bool symmetric) {
    super.Constructor(results.Data);
    Results    = results;
    Symmetric  = symmetric;

    var data = results.Data;
    Rule       = data.Rule;
    Partitions = Rule.Partitions;

    var matrix  = Matrix.Convert(rates);
    var ordered = data.UniqueSegments;
    var length  = LegendSegments.Length;

    System.Assert(length == matrix.Rows);
    System.Assert(length == matrix.Cols);
    System.Assert(length == ordered.Length);

    RateMatrix = new(length, length, null);
    RateList   = new(length * length);

    double min  = 100.0;
    double max  = -100.0;
    double dmin = 100.0;
    double dmax = -100.0;

    for (var i = 0; i < length; ++i) {
      for (var j = 0; j < length; ++j) {
        var r = new SegmentRate(Results, this, ordered[i], ordered[j], matrix[i, j], matrix[j, i], symmetric, i == j);
        RateMatrix[i, j] = r;
        if (i == j) {
          dmax = Math.Max(dmax, r.Rate);
          dmin = Math.Min(dmin, r.Rate);
        }
        else {
          RateList.Add(r);
          max = Math.Max(max, r.Rate);
          min = Math.Min(min, r.Rate);
        }
      }
    }

    if (dmax > 0)
      DiagFactor = 1.0 / Math.Abs(Math.Max(dmin, dmax));
    else
      DiagFactor = 1.0;
    RateFactor      = 1.0 / Math.Abs(Math.Max(min, max));
    DirFactor       = max == min ? 1.0 : 1.0 / Math.Abs(max - min);
    var rl = RateList.ToArray;
    SortedRates     = rl.ToSortedArray(SegmentRate.SortDescending, @SegmentRate.CompareRate);
    SortByDirection = rl.ToSortedArray(SegmentRate.SortDescending, @SegmentRate.CompareDirection);
  }

  override CountBox AddEntry(SegmentPart si, SegmentPart sj) {
    if (si.Index == sj.Index)
      return CountBox.Null;

    var rate = RateMatrix[si.Index, sj.Index];
    return new(Span {TextHeight: 40%; TextDigits: 2; TextScientific: true; rate.Original}, Math.Log(rate.Original), rate);
  }

  ShowLegend(SegmentRate[] rates) {
    // Show only partitions that are present in the chart
    var pmax = Partitions.Length;
    var set  = new HashSet<SegmentPartition>(pmax);
    foreach (var s in rates) {
      set.Add(s.S0.Partition);
      set.Add(s.S1.Partition);
    }

    return Canvas(ExtentWidth) {
      HAlign: Center;
      Rule.ShowBlockLegend(set.ToArray, 11pt);
    }
  }

  ShowChart(SegmentRate[] rates) = Chart(100%, 4") {
    ChartType: ChartTypes.Column;
    TextHeight: 12pt;
    ValueLabel: PaperStyle.ValueLabel {
      Lang.RateFactor;
    };

    var fs = Math.Min(160.0 / rates.Length, 10pt);
    XAxis: ChartAxis {
      Rotation: 30 degrees;
      (each rates).ShowBox(fs);
    };

    ChartSeries(Colors.Green) {
      Label: Tex.rightarrow;
      foreach (var a in rates)
        new DataPoint(each0, a.Rate) {Reference: a};
    };
  };

  Extrema(number, top) = VBox {
    var actions = SortedRates.Slice(top ? 0..<number : (SortedRates.Length - number)..<SortedRates.Length);
    ShowChart(actions);
    Separation: 20pt;
    ShowLegend(actions);
  };

  ShowAllRates = VBox {
    Chart(100%, Math.Min(6", ExtentHeight - 48pt)) {
      ChartType: ChartTypes.Scatter;
      TextHeight: 12pt;
      TipNoPublish: true;

      ValueLabel: PaperStyle.ValueLabel {
        RateDescriptor(Lang.RateFactor);
      };

      XAxis: ChartAxis {
        TextHeight: 7pt;
        foreach (var sa in LegendSegments) {
          var p = Partitions[sa.PartitionIndex];
          HBox(15pt) {
            HAlign: Center;
            Background: p.BackColor;
            TextColor: p.TextColor;
            sa.Segment.Ipa;
          }
        }
      };

      ChartSeries {
        Marker: Markers.Dot;

        foreach (var si in LegendSegments) {
          var i = each0;

          foreach (var sj in LegendSegments) {
            if (si.Index != sj.Index) {
              var a = RateMatrix[si.Index, sj.Index];
              if (a is not null) {
                new DataPoint(i, a.Rate) {
                  Reference: a;
                  Fill: a.S1.Partition.BackColor;
                };
              }
            }
          }
        }
      };
    };

    Separation: 20pt;
    Canvas(ExtentWidth) {
      HAlign: Center;
      Rule.ShowBlockLegend(Partitions, 10pt);
    }
  };

  ShowDirection = VBox {
    Chart(100%, Math.Min(6", ExtentHeight - 48pt)) {
      TipNoPublish: true;
      ChartType: ChartTypes.Scatter;
      TextHeight: 12pt;

      XLabel: "Transitions";

      ValueLabel: PaperStyle.ValueLabel {
        RateDescriptor("Direction");
      };

      var group   = Markers.TriangleUp(Colors.Green) {TextHeight: 8pt};
      var special = Markers.Square(Colors.Red) {TextHeight: 10pt};
      ChartSeries {
        TextHeight: 6pt;
        Marker: Markers.Dot;
        foreach (var a in SortByDirection) {
          new DataPoint(each0, a.Direction) {
            Reference: a;
            if (a.S0.Segment.Ipa == "p")
              Marker: a.S1.Segment.Ipa == "b" or a.S1.Segment.Ipa == "f" ? special : group;
            else
              Marker: a.S0.Partition.Marker;
          }
        }
      };
    };

    Separation: 20pt;
    Canvas(ExtentWidth) {
      HAlign: Center;
      Rule.ShowBlockLegend(Partitions, 10pt);
    }
  };

  ShowChartPairs(top, SegmentRate[] rates) = VBox {
    var subset = top < 0 ? rates : rates.Slice(0..<top);

    ShowChart(subset) {
      ChartType: ChartTypes.StackedColumn;

      Legend: ChartLegend {
        Direction: Directions.Vertical;
        Placement: Placements.Right;
      };
      ChartSeries(Colors.Red) {
        Label: Tex.leftarrow;
        foreach (var a in subset)
          new DataPoint(each0, a.Reverse);
      };
    };
    Separation: 20pt;
    ShowLegend(subset);
  };

  Pairs(top, FindRateDelegate predicate) = ShowChartPairs(top, SortedRates.FindSlice(predicate));
}

//======================================================================

class CalcRatesClass {
  var ExperimentData   Data;
  var RateTransition   Transition;
  var PartitionRule    Rule;
  var RunResultsThread Run;
  var                  MaxLine,
                       ArrowGap,
                       GapAngle,
                       LoopRadius,
                       LoopDistance,
                       MaxExtent,
                       MaxRadius,
                       RateScale;

  Constructor(ExperimentData data, RunResultsThread run) {
    Run        = run;
    Data       = data;
    Rule       = Data.Rule;
    ArrowGap   = 8pt;
    GapAngle   = 80.0 degrees;
    Transition = new RateTransition(run, Rule);
  }

  void Calibrate(Size size) {
    var middle = new Point(size.Width * 0.5, size.Height * 0.5);

    MaxExtent    = Math.Min(middle.X, middle.Y);
    MaxRadius    = MaxExtent * 0.2;
    MaxLine      = MaxRadius * 0.3;
    LoopRadius   = MaxRadius * 0.25;
    LoopDistance = LoopRadius * 0.5;


    var fmax = MaxRadius / Math.Sqrt(Transition.MaxFrequency); // Proportional to area, so use SQRT of frequency

    RateScale = MaxLine / Transition.MaxRate;

    var mult = Math.PI2 / Rule.Partitions.Length;
    var eq   = Run.EquilibriumFrequencies;

    foreach (var partition in Rule.Partitions) {
      partition.Angle  = mult * each0 - Graphics.Ninety;
      partition.Radius = Math.Sqrt(eq[each0]) * fmax;
    }

    var maxradius = 0.0;
    foreach (var partition in Rule.Partitions)
      maxradius = Math.Max(maxradius, partition.Radius + Transition.Rates[each0, each0].Upper * RateScale);
    maxradius = MaxExtent - maxradius - LoopRadius - LoopDistance - ArrowGap;

    foreach (var partition in Rule.Partitions)
      partition.Center = Graphics.ExtendPoint(middle, maxradius, partition.Angle);
  }

  private MainDiagram(ContentStyle style, min) = Canvas(min, min) {
    TransformFit: true;
    style.SansSerif;

    Calibrate(new(min));

    foreach (var p1 in Rule.Partitions) {
      var i = each0;

      foreach (var p2 in Rule.Partitions) {
        var rate = Transition.Rates[each0, i];
        if (rate is valid) {
          var  hover = new PartitionAction(Rule, rate, p1, p2);

          if (p1 == p2) {
            var line2 = new LineStyleClass(rate.Mean * RateScale, 0.25, 1);
            var c     = Graphics.ExtendPoint(p1.Center, p1.Radius + LoopDistance - line2.LineSize*0.5, p1.Angle);
            Graphics.CircleLine(line2, c, LoopRadius + line2.LineSize, p1.Angle + Graphics.OneEighty, GapAngle) {
              TipAction: hover;
            };
          }
          else if (each0 < i) {
            var angle = Graphics.GetAngle(p1.Center, p2.Center);
            var c1    = Graphics.Adjust(p1.Center, p1.Radius + ArrowGap, angle + Graphics.OneEighty);
            var c2    = Graphics.Adjust(p2.Center, p2.Radius + ArrowGap, angle);

            Graphics.Line(new(rate.Mean * RateScale, 0.25, 1), c1, c2) {
              TipAction: hover;
            }
          }
        }
      }
    }

    foreach (var p1 in Rule.Partitions) {
      var pos        = p1.Center - p1.Radius;
      var fsize      = p1.Radius*2;
      var textheight = Math.Min(14pt, fsize * 0.5);

      Shape(p1.BackColor, 0.5pt) {
        EllipsePath(new(pos, new(fsize)));
        TipAction: p1;
      };

      Canvas(fsize, fsize) {
        X: pos.X;
        Y: pos.Y;
        HAlign: Center;
        VAlign: Center;
        Span {
          TextHeight: textheight;
          TextColor: p1.BackColor.TextCompliment;
          p1.Index+1;
        };
      };
    }
  };


  PartitionDiagram(ContentStyle style) = HBox {
    VAlign: Center;

    var legend = Rule.ShowLegend(style, 10pt, 0);
    var ls     = GetLayoutSize(legend);
    legend;
    MainDiagram(style, Math.Min(ExtentWidth - ls.Width, ExtentHeight));
  };

  TranLink(i0, i1) = "Tran{0}:{1}"(i0, i1);
}

//======================================================================

class DiagonalClass {
  var List<SegDataClass> Diagonal;
  var PartitionRule      Rule;

  Constructor(PartitionRule rule, AlignedCountClass rates) {
    Rule = rule;
    var m      = rates.RateMatrix;
    var length = m.Cols;

    Diagonal = new(length);
    for (int i = 0; i < length; ++i) {
      var r = m[i, i];
      if (r is not null)
        Diagonal.Add(new(r));
    }
    Diagonal.Sort(true, @CompareData);
  }

  static int CompareData(SegDataClass d0, SegDataClass d1) = d0.Value.Compare(d1.Value);

  SegmentPartition[] OrderPartitions {
    var partitions = new HashSet<SegmentPartition>(Rule.Partitions.Length);
    foreach (var d in Diagonal)
      partitions.Add(d.Rate.S0.Partition);
    return partitions.ToArray;
  }

  Display(ContentStyle style) = VBox {
    HAlign: Center;
    style.SansSerif;

    Chart(100%, 2") {
      TextHeight: 11pt;
      ChartType: ChartTypes.Column;

      ValueLabel: PaperStyle.ValueLabel {
        Span {Lang.Rate};
      };

      XAxis: ChartAxis {
        TextHeight: PaperStyle.SegmentTextFactor * ExtentWidth / Diagonal.Length;
        foreach (var d in Diagonal)
          d.Rate.S0.ShowSegment;
      };

      ValueAxis: ChartAxis;
      ChartSeries {
        foreach (var d in Diagonal) {
          new DataPoint(each0, d.Value) {
            Reference: d;
            Fill: d.Rate.S0.Partition.BackColor;
          };
        }
      };
    };

    Rule.ShowBlockLegend(OrderPartitions, 7pt);
  };
}

//======================================================================

class PartitionAction: Action {
  var StatClass        Rate;
  var SegmentPartition P1,
                       P2;

  Constructor(PartitionRule rule, StatClass rate, SegmentPartition p1, SegmentPartition p2) {
    super.Constructor(Actions.ToSource, rule, Guid.FromHash("partitionrate{0}{1}"(p1.FactId, p2.FactId)));
    Rate = rate;
    P1   = p1;
    P2   = p2;
  }

  AddGroup(SegmentPartition p) = VBox {
    HAlign: Center;
    HBox {
      TextBackground: 90%;
      Span {
        p.Name;
      };
    };
    HBox {
      p.ShowFilterSegments(ParAlignments.Center);
    };
  };

  override GetLayoutTip = HBox {
    VAlign: Top;
    AddGroup(P1);
    var t = PadLR(5);
    HBox(null, null, t) {
      Margin: t;
      VBox {
        HAlign: Center;
        Span {Lang.Rate; "%"};
        Rate.ShowBox;
      };
    };
    AddGroup(P2);
  };
}

//======================================================================

class AlignSort {
  var AlignData  Data;
  var AlignIndexClass Congate;

  Constructor(AlignData data, AlignIndexClass cognate) {
    Data    = data;
    Congate = cognate;
  }
}

