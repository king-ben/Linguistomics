//======================================================================

class DataViewOptions: Fact {
  field int    Model;
  field string Name;

  Constructor {
    super.Constructor(#f522fb93-5db9-43fe-b84f-c0fe664f9e1c#);
    Name = "Test";
    ReadFromStorage;
  }
}

//======================================================================

readonly DataViewOptions ViewOptions = new;

readonly namespace Main.Documents {
  TestResultsDocument TestResults = new;
}

//======================================================================

class ExperimentResults {
  var ExperimentData   Data;
  var ModelConfig      Model;
  var ModelConfig[]    Models;
  var RunResultsThread MainRun;
  var AlignmentChart   Alignment;

  Constructor {
    Data = new(ViewOptions.Name, 1..1);
    Data.ReadExperiment;
    Models  = Data.TreeSets[0].Models;

    ViewOptions.Model = Math.Min(ViewOptions.Model, Models.Length-1);
    Model   = Models[ViewOptions.Model];
    MainRun = new(Data, Model.Run[0]);
    Parallel.ParallelEach([MainRun], 100%);

    Alignment = new(Data, MainRun);
  }
}

//======================================================================

class TestResultsDocument: DocumentEntry {
  var ContentStyle      Style;
  var ExperimentResults Results;
  var RunResultsThread  MainRun;
  var List<Content>     PaperContent;

  Constructor {
    super.Constructor(#c763a1b9-9722-44c0-8729-ce88984273ae#, "Test Results");
    Style        = new PlainStyle;
    Results      = new ExperimentResults;
    MainRun      = Results.MainRun;
    PaperContent = new(16);

    if (MainRun.NCQFreqs is valid) {
      AddContent(new EquilibriumFrequencyChart(MainRun));
      AddContent(new NaturalClassRateChart(MainRun));
      AddContent(new SegmentalChangeFigure(MainRun));
    }

    var q = MainRun.QRates;
    AddContent(new QRatesMatrixFigure(q));
    AddContent(new QRatesDiagonalFigure(q));
    AddContent(new GapFrequencyChart(MainRun));
    AddContent(new QRatesCCFigure(q));
    AddContent(new SpecificRatesFigure(q));
    AddContent(new QRatesOneWayFigure(q));
    AddContent(new QRatesTopFigure(q));
  }


  void AddContent(Content c) {
    PaperContent.Add(c);
  }

  Header = Style.HeadingPar(0);

  override GetDocument = Document(0.5") {
    var edge = new Edge(0.5, 6);
    Paragraph {
      TextControl(new(ref ViewOptions.Name), 2", null, edge) {
        Placement: Placements.Left;
        Action: Actions.Rebuild;
        Bold; "Folder";
      };
      Space * 4;

      HBox(null, null, edge) {
        Separation: 20pt;
        BorderRadius: 7;
        Bold "Model ";

        foreach (var model in Results.Models) {
          if (model.IsLoaded()) {
            RadioControl(new(ref ViewOptions.Model), each0) {
              Placement: Placements.Right;
              Action: Actions.Rebuild;
              model.Name;
            };
          }
        }
      };
    };

    Style.TitlePar {
      TextHeight: 14pt;

      Results.Data.Name;
      " - ";
      Results.Model.Name;
      " model";
    };

    var run = MainRun.Run;
    if (run.ResultTree is valid) {
      Header {"Consensus"};
      PaperStyle.ShowTree(Style, run.ResultTree, 100%, null);
    }

    var alignment = Results.Alignment;
    if (alignment is valid and Results.MainRun.QRates is valid) {

      foreach (var c in PaperContent) {
  //      PageBreak;
        Header {c.Title};
  //      c.GetCaption(Style);
        c.GetBody(Style);
      }

      PageBreak;
      Header {"Alignments"};
      alignment.ShowAll;
    }
  };
}

//===============================================================

class PlainStyle: ContentStyle {
  Constructor {
    super.Constructor(ReferenceStyles.IEEE, null, 0.75", SectionNumbers);
    TexPackages.AddEach(["fontspec"]);
    TexFont   = "Libertinus Serif";
    SansSerif = TextFamily: TextFamilies.LibertinusSans;
  }

  override SetTextStyle = {
    TextHeight: 12pt;
    TextFamily: TextFamilies.LibertinusSerif;
  };
}

