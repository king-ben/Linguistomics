//======================================================================

enum ViewModels {
  Custom,
  JC69,
  GTR,
}

class DataViewOptions: Fact {
  field int Model;

  Constructor {
    super.Constructor(#6fa7029e-1371-4068-916f-b04a7b06a182#);
    ReadFromStorage;
  }
}

//======================================================================

readonly DataViewOptions ViewOptions = new;

readonly Main.Facts = [WorldLanguages];

SimpleStyle = new PlainStyle;

readonly namespace Main.Documents {
  TestResultsDocument TestResults = new(MainResults);
}

readonly ExperimentResults MainResults = new;

//======================================================================

class ExperimentResults {
  var ExperimentData   Data;
  var ModelConfig      Model;
  var RunResultsThread MainRun;
  var AlignmentChart   Alignment;

  Constructor {
    Data    = new(null, "Test", "Test", 1..1);
    Model   = Data.TreeSets[0].Models[ViewOptions.Model];
    MainRun = new(Data, Model.Run[0]);
    Parallel.ParallelEach([MainRun], 100%);

    Alignment = new(Data, MainRun);
  }
}

//======================================================================

class TestResultsDocument: DocumentEntry {
  var ContentStyle      Style;
  var ExperimentRun     Run;
  var ExperimentResults Results;
  var List<Content>     PaperContent;

  Constructor(ExperimentResults results) {
    super.Constructor(#c763a1b9-9722-44c0-8729-ce88984273ae#, "Test Results");
    Style        = SimpleStyle;
    Results      = results;
    Run          = results.MainRun.Run;
    PaperContent = new(16);

    if (Results.MainRun.NCQFreqs is valid) {
      AddContent(Figures.EquilibriumCharts);
      AddContent(Figures.RateChart);
      AddContent(Figures.TransitionRates);
    }

    AddContent(Figures.QRatesDiagonal);
    AddContent(Figures.GappinessChart);
    AddContent(Figures.QRatesConsonantConsonant);
    AddContent(Figures.SpecificRates);
    AddContent(Figures.QRatesOneWay);
    AddContent(Figures.QRatesTop);
  }

  void AddContent(Content c) {
    PaperContent.Add(c);
  }

  Header = Style.HeadingPar(0);

  override GetDocument = Document(0.5") {
    Style.TitlePar {
      TextHeight: 14pt;

      Results.Data.Name;
      " - ";

      IntControl(new(ref ViewOptions.Model), 24pt, null, new Edge(1, 3, Colors.Gray), 0, 2, 1) {
        "Model";
        BorderRadius: 5;
        Action: Actions.Rebuild;
      };
      Space;
      MainResults.Model.Name;
    };

    Header {"Consensus"};
    PaperStyle.ShowTree(SimpleStyle, Run.ResultTree, 100%, null);

    foreach (var c in PaperContent) {
//      PageBreak;
      Header {c.Title};
//      c.GetCaption(Style);
      c.GetBody(Style);
    }

    PageBreak;
    Header {"Alignments"};
    MainResults.Alignment.ShowAll;
  };
}

//===============================================================

class PlainStyle: ContentStyle {
  Constructor {
    super.Constructor(ReferenceStyles.IEEE, null, 0.75", SectionNumbers);
    TexPackages.AddEach(["fontspec"]);
    TexFont   = "Libertinus Serif";
    SansSerif = TextFamily: TextFamilies.LibertinusSans;
  }

  override SetTextStyle = {
    TextHeight: 12pt;
    TextFamily: TextFamilies.LibertinusSerif;
  };
}

