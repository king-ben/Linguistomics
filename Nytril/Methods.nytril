readonly WorkflowFigure Figures.Workflow = new;

class WorkflowFigure: Content {
  Constructor {
    super.Constructor("Workflow");
  }

  override GetCaption(ContentStyle style) = Span {
    "The workflow of the experiment.";
  };

  Arrow(arrow) = Span {
    TextHeight: 30;
    arrow;
  };

  Box(index, text) = VBox(110, 96, new Edge(2, 3, Colors.DarkGray)) {
    TextFace: TextFaces.SansSerif;
    TextHeight: 14pt;
    VAlign: Center;
    BorderRadius: 16;
    Background: Color.ChartColor(index);
    TextColor: Colors.White;

    Frame(100%) {
      ParAlignment: Center;
      text;
    };
  };

  override GetBody(ContentStyle style) = HBox(100%) {
    HAlign: Center;
    VBox {
      HAlign: Right;
      Margin: PadB(10);
      HBox {
        VAlign: Center;
        HBox {
          VAlign: Center;
          Bracket: Brackets.FlatRound;
          Box(0, ["Segment", "Library", "(static)"]);
          Arrow(Tex.Plus);
          Box(1, ["Cognate", "Data"]);
        };
        Arrow(Tex.rightarrow);
        Box(2, ["Parsing", "&", "Validation"]);
        Arrow(Tex.rightarrow);
        Box(3, ["Create", "MCMC", "Dataset"]);
      };

      Span {
        HAlignment: Right;
        TextHeight: 30;
        Tex.downarrow;
        Space*5;
      };

      HBox {
        Margin: PadT(5);
        VAlign: Center;
        Box(7, ["Manuscript", "&", "Supplements"]);
        Arrow(Tex.leftarrow);
        Box(6, ["Figures", "&", "Narrative"]);
        Arrow(Tex.leftarrow);
        Box(5, ["Compute", "Rates"]);
        Arrow(Tex.leftarrow);
        Box(4, ["Run", "MCMC", Icons.hourglass_top]);
      };
    };
  };
}

