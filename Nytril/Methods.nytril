readonly UsedCognatesSection PaperSections.UsedCognates = new;

class UsedCognatesSection: Content {
  Constructor {
    super.Constructor("Cognates Used in the Paper");
  }

  override GetBody(ContentStyle style) = Block {
    var data = MainResults.Data;

    style.ReviewNewBlock {
      style.Par {
        "In total, the dataset contains "; data.UsedCognates.Length;
        " cognate sets that comprise "; data.WordCount;
        " word-forms containing "; data.UniqueSegments.Length;
        " unique segments drawn from the following "; data.UsedConcepts.Length; " concepts: ";
        PaperDataSection.ConceptList(data, style); DotSpace;
      };
    };
  };
}

//======================================================================

readonly WorkflowSection PaperSections.Workflow = new;

class WorkflowSection: Content {
  Constructor {
    super.Constructor("Workflow");
  }

  override GetBody(ContentStyle style) = Block {
    var code = Span {TextFace: TextFaces.Mono};

    style.ReviewNewBlock {
      style.Par {
        "The first step in the experiment was to create a dictionary of IPA segment information. ";
        "The files "; code {"IPA.nytril"}; "  and  "; code {"Segments.nytril"}; " contain the definitions of these classes and the information about each segment is encoded in separate instances of the these classes. ";
        "The definition of a segment includes the IPA symbol string {e.g. "; VocalSegments.nya; ") and a variety of flags and properties indicating the vocal attributes of the segment (e.g. Vowel, Sibilant, Fricative, etc...) ";
        "These files are designed to be reusable for future experiments, and by other researchers. ";
      };
      style.Par {
        "Next is the aggregation of cognate words, stored in nytril source files as strings, organized by category and language. ";
        "The strings contain UCS code points encoding the IPA symbol for each segment, making it easy to copy and paste from different sources. ";
        "The dashes between the IPA characters serve to align the positions of the segments vertically, providing the initial alignment for the experiment. ";
        "The words also may contain syllable stress marks, but these are ignored for this experiment. ";
        "The format of this file was created to facilitate the collection and editing by the researchers. ";
        "Although these word files are organized by parts of speech (e.g. "; code{"Nouns.nytril"}; ", "; code{"Adjectives.nytril"}; ", etc..), this has no effect other than to break them up into smaller chunks for easier editing. ";
        "In other words, it is organized in the way that makes the most sense to a linguist, but when processed, they are aggregated and sorted in a different way. ";
      };
      style.Par {
        "The next step involves software. The strings are decoded and the UCS code points are turned into an array of VocalSegment objects. ";
        "Since the IPA characters contain diacritic marks and have a variable length, the code points in the strings must be normalized to a specific form before being compared. ";
        "We chose Form C (NFC - Canonical precomposition), but the goal is that the diacritics are in the same relative position in all strings, for accurate comparison. ";
        "Once these strings are parsed to object pointers, they are tested by converting them back to a string to confirm that they produce the same sequence as the starting point. ";
        "The segment objects are next grouped into words, and associated by category, cognate and language until the final result is a large conventional data structure representing all of the raw data in the experiment. ";
      };
      style.Par {
        "The next step is to produce a series of diagnostic documents that show the data in a variety of tables and charts. ";
        "The goal is to slice the words and data in different ways to allow the researcher to spot any mistakes in alignments or composition. ";
      };
      style.Par {
        "When the team is statisfied that the data is well formed, a process is run to take all of the data and create an experiment snapshot. ";
        "This builds a folder full of various files in nytril and JSON format, that are read by the TongueTwister program. ";
      };
      style.Par {
        "TongueTwister performs the MCMC calculations (that run for several days) and produce a large series of tree files and other data. ";
        "After this is complete, these files are read by another program called TongueTwisterReader that does the final statistical aggregation and produces final output files in the nytril format. ";
      };

      style.AddFigure(Figures.Workflow, FigureOptions.Bottom | FigureOptions.Full);

      style.Par {
        "Finally, these files are read by a program written in nytril that takes the final output files and produces a series of tables, charts and figures. ";
        "These figures are combined with narrative from the researchers, to produce the final paper and presentation slide decks. ";
        style.FigureReference(Figures.Workflow); " shows a model of this workflow. ";
      };
    };
  };
}

//======================================================================

SegmentTable(ContentStyle style, ExampleConcept example, ExperimentData data, aligned) = style.BodyTable([1", 14pt]) {
  var words = example.Cognate.Words;
  foreach (var taxon in data.Taxa) {
    Row {
      taxon.Language;
      var w    = words[taxon.Index];
      var list = aligned ? w.Padded : w.Segments;
      foreach (var s in list)
        s.ShowSegment;
    }
  }
};

//======================================================================

readonly RateMatrixSection PaperSections.RateMatrixDiscussion = new;

class RateMatrixSection: Content {
  Constructor {
    super.Constructor("Rate Matrix Discussion");
  }

  override GetBody(ContentStyle style) = Block {
    style.Par {
      "Our model describes how the segments evolve along the branches of the tree. We have three events that can occur to change a word: an insertion of a single segment, a deletion of a single segment, and a substitution of a segment.";
    };

    style.Par {
      "A substitution is the replacement of one segment by another. We model substitutions as occurring according to a continuous-time Markov model. Such a model can be understood if you know two things: the possible states and the rate of change between all pairs of states. For our work, the states are the "; MainResults.Data.UniqueSegments.Length; " possible segments. The rates of change between all pairs of states are contained in a rate matrix, which we denote "; RateMatrix; DotSpace;
    };

    style.Par {
      "You can completely describe the substitution process if you have "; RateMatrix; DotSpace; "We use "; RateMatrix; " to calculate transition probabilities (by exponentiating the product of the rate matrix and the branch length) and also to get the stationary frequencies of the process (which are the probability of capturing the process in some state after infinite time has passed)."
    };

    style.Par {
      "Now, for understanding the rate matrix. Let’s denote "; qij; " as the rate of change from state "; sym.i; " to state "; sym.j; ". (It’s simply an element of the rate matrix, "; RateMatrix; "). This is literally the rate of change to that state when the process is in state "; sym.i; ". Comparing rates in the rate matrix can be useful. You can say things such as, “ This rate is higher than that rate. This makes sense because everyone knows that such changes occur frequently in language.” I would especially compare rates in a single row. Does it make sense to see, for example, that when changes occur, they are more likely to be to other states in the same class? Does it make sense that when we have a change and a segment is in the green class that it is more likely to be to a segment in the dark gray and brown classes? That’s how I read ";
      style.FigureReference(Figures.QRatesMatrix); DotSpace;
    };

    style.AddFigure(Figures.QRatesMatrix, FigureOptions.Bottom | FigureOptions.Full);

    style.Par {
      "That said, I think the diagonals are quite interesting because they give you an idea of the relative volatility of the segments. The diagonals are simply the negative of the sum of the off-diagonal components of the row:"
    };

    style.AlignEquation(Equations.OffDiagonalComponents);

    style.Par {
      "where "; sym.j; " is iterated over all states (for "; sym.i; Tex.neq; sym.j; "). What does this mean? Let’s consider two segments one of which has a diagonal value of –1.0 and the other that has a value of –2.0. The rate of change for the first, then, is 1.0 and the second is 2.0. This means that the second segment is in a sense more volatile than the first. When we are in the second segment, we move to another state at a rate 2.0 which is twice the rate of the first segment."
    };

    style.Par {
      "What should you look for here with respect to the linguistic data? Well, I don’t know. I’m hoping that, with this interpretation under his belt, David will see patterns that make sense. Are certain segments known to be more volatile in language? Are others known to be more conservative? Does this background knowledge in the field match up with the rates we are getting (the diagonal values)?"
    };

    style.Par {
      "The other graphs show the average rates. The average rates can be calculated from the rate matrix, "; RateMatrix; ". To distinguish the average rate matrix from the rate matrix, "; RateMatrix; ", I will denote it "; AverageMatrix; ". The "; sym.ij sup "th"; " element of this average rate matrix is calculated as "; AverageRateElement; ". In words, the average rate of change from state "; sym.i; " to state "; sym.j; " is equal to the probability of starting in state "; sym.i; " and then moving to state "; sym.j; "."
    };

    style.Par {
      "What do the average rates tell us? I think the interpretation is a little more confusing, but still well defined. We are looking at averages now, over all the characters and taking into account their frequencies. A segment that is frequent in the data set will have a boost, here, because "; Probability sub sym.i; " will be higher."
    };

    style.Par {
      "Perhaps the best way to think of this is as follows: "; AverageMatrix; " tells you the average rates and takes into account the probability of starting in state "; sym.i; DotSpace; RateMatrix; ", by contrast, assumes you are already in state "; sym.i; " and tells you how rapidly you move to various states (from "; sym.i; " to the other possible states). I believe for our purposes, you should concentrate on "; RateMatrix; DotSpace;
    };
  };
}
