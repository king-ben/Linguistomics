readonly ConclusionSection PaperSections.Conclusion = new;

class ConclusionSection: Content {
  Constructor {
    super.Constructor("Conclusion");
  }

  override GetBody(ContentStyle style) = Block {
    style.Par {
      style.ReviewMark(ReviewComments.C24);
      "We present the first application of the TKF91 model to a linguistic dataset and argued that an event-based approach to language evolution offers significant advantages over current practices. ";
      "We believe the method can be extended to handle more complex segmental changes (such as those involving context dependency). ";
      "Moreover, the event-based approach has the potential to improve divergence-time ";
      style.ReviewOld {
        "estinmation";
      };
      style.ReviewNew {
        "estimation";
      };
      ", which relies on estimating the number of events that occurred along the branches of the tree. ";
      "When applied to abstract cognate relationships, it is unclear what events are actually being counted along the branches. ";
      "By contrast, the possible events in our event-based approach are well defined: segmental transitions, insertions, or deletions.";
    };

    style.AddFigure(Figures.AlignmentExample2, FigureOptions.Bottom | FigureOptions.Full);

    style.AddFigure(Figures.ConceptEncoding, FigureOptions.Bottom);

    style.AddFigure(Figures.SegmentEncoding, FigureOptions.Bottom, 50%);

    style.Par {
      "The code and data for this study are available on ";
      Span {
        TipAction: new URL("https://github.com/jhuelsenbeck/Linguistomics");
        TextColor: Colors.Blue;
        "GitHub";
      };
      DotSpace;
    };
  };
}

