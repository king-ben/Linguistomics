readonly ManualAlignmentFigure TableFigures.ManualAlignment = new(MainResults.Data);

class ManualAlignmentFigure: Content {
  var ExperimentData Data;

  Constructor(ExperimentData data) {
    super.Constructor("An example of an aligned cognate set");
    Data = data;
  }

  WordDisplay(ContentStyle style) = style.SQuoteEnd {
    TextCase: AllLower;
    Data.FigureConcept.Name;
  };

  override GetCaption(ContentStyle style) = Span {
    "Manual alignment of the words for the concept ";
    WordDisplay(style);
  };

  override GetBody(ContentStyle style) = LanguageTable([Column.Fit(2"), Column.Fit(3"), Column.Fit(1.5")]) {
    ParAlignment: Center;
    TextHeight: Math.Max(ExtentWidth * 0.02, 9pt);

    var cognate = Data.GetCognate(Data.FigureConcept);
    LanguageTitleRow {
      Lang.Language;
      Lang.PhonemicRep;
      Lang.Alignment;
    };

    foreach (var word in cognate.Words) {
      Row {
        word.Language;
        TextIpa {word};
        word.ShowPadded;
      }
    }
  };
}

