readonly SegmentModelsFigure PaperSections.SegmentModels = new;

class SegmentModelsFigure: Content {
  Constructor {
    super.Constructor("Models of segmental change");
  }

  override GetBody(ContentStyle style) = Block {
    var data     = MainResults.Data;
    var rule     = data.Rule;
    var segments = data.UniqueSegments.Length - 1;
    var rp       = rule.Filters.Length;

    style.Par {
      "We evaluate three models of segmental change. ";
      PoissonModel; " is isomorphic to the Jukes–Cantor model of DNA sequence evolution";
      Citep {Jukes1969};
      ", which specifies equal transition rates among all pairs of states, with substitutions occurring according to a Poisson process (hereafter the "; style.SQuote{PoissonModel.Name}; " model). ";
      UnequalModel; ", corresponds to the Felsenstein model";
      Citep {Felsenstein1981};
      ", in which the substitution rate from one segment to another is proportional to the equilibrium frequency of the destination segment. ";
      "Finally, "; NaturalClassModel; ", the "; NaturalModelName; ", partitions segments into articulatorily defined natural classes and permits distinct rates of change within and between these classes. ";
      "Model complexity differs substantially across these specifications. ";
      PoissonModel; " contains no free parameters. ";
      UnequalModel; " includes "; segments; " free parameters corresponding to the equilibrium frequencies (one fewer than the number of segments). ";
      "The "; NaturalModelName; ", "; NaturalClassModel; ", has "; rp*(rp-1)/2 + rp; " additional rate parameters governing transitions among natural classes, which yields a total of ";
      EqSpan {segments; Tex.Plus; (rp*(rp-1)/2 + rp); Tex.Equals; segments + rp*(rp-1)/2 + rp}; " free parameters.";
    };
  };
}

//======================================================================

readonly ModelComparisonSection PaperSections.ModelComparison = new;

class ModelComparisonSection: Content {
  Constructor {
    super.Constructor("Model Comparison");
  }

  override GetBody(ContentStyle style) = Block {
    style.Par {
      "We assessed the relative fit of the three segmental-change models introduced in "; style.SectionReference(PaperSections.MethodsSection); " using Bayes factors. ";
      "The Bayes factor is the ratio of the marginal likelihoods of the models: ";
    };

    style.AlignEquation(Equations.BayesFactorEq);

    style.Par {
      "Ratios greater than one indicate evidence in favor of model "; ModelI; ". ";
      "Since the candidate models are nested, we computed the Bayes factor via the Savage-Dickey density ratio";
        Citep {Dickey1971}; ", ";
        "which evaluates the ratio of posterior to prior densities at the parameter restriction that reduces the richer model to the simpler one. ";
      "The "; NaturalModelName; " explains the data substantially better than the two simpler alternatives. ";
      "The log Bayes factors are ";
      // TODO: Maybe update the log bayes factor numbers dynamically, though this will be more tricky.
      EqSpan{Tex.ln; BayesFactor12; Tex.Equals; -1074.2};
      " and ";
      EqSpan{Tex.ln; BayesFactor23; Tex.Equals; -117.3};
      ", comparing ";
      PoissonModel;
      " to ";
      UnequalModel;
      " and ";
      UnequalModel;
      " to ";
      NaturalClassModel;
      ", respectively. ";
      "This difference constitutes overwhelming support for the more parameter-rich "; NaturalModelName;
      Citep {Jeffreys1939}; DotSpace;
    };
 };
}

