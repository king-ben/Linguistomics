readonly EquilibriumFrequencyChart Figures.EquilibriumCharts = new;

class EquilibriumFrequencyChart: Content {
  Constructor {
    super.Constructor("Equilibrium frequency chart");
  }

  override GetCaption(ContentStyle style) = Span {
    "The equilibrium frequencies "; EquilibriumDistribution; " of each natural class";
  };

  override GetBody(ContentStyle style) = Chart(100%, 2.75") {
    ChartType: ChartTypes.Bar;
    style.SansSerif;
    TextHeight: 11pt;

    ValueLabel: Span {
      TextHeight: 20pt;
      EquilibriumDistribution;
    };

    var partitions = MainResults.Data.Rule.Partitions.Reverse;
    var stats      = MainResults.MainRun.NCQFreqs;

    XAxis: ChartAxis(null, null, PadR(8)) {
      foreach (var p in partitions) {
        Span {
          Tip: p;
          TextColor: p.BackColor;
          p.Name;
        }
      }
    };

    ChartSeries {
      foreach (var p in partitions) {
        var c = stats[p.Index];
        new DataPoint(each0, c.Mean) {
          ErrorLo: c.Mean - c.Lower;
          ErrorHi: c.Upper - c.Mean;
          Reference: c;
          Fill: p.BackColor;
        }
      }
    };
  };
}

//======================================================================

readonly GapFrequencyChart Figures.GappinessChart = new;

class GapFrequencyChart: Content {
  Constructor {
    super.Constructor("Gap frequency comparison chart");
  }

  override GetCaption(ContentStyle style) = Span {
    "Distribution of alignment gaps across word positions for the "; MainResults.Data.UsedCognates.Length; " cognate sets analyzed in this study. ";
    "The top panel shows the proportion of alignments with a given number of gaps at the word-initial segment, the middle panel at word-internal segments, and the bottom panel at the word-final segment. ";
    "Since nine languages are analyzed, at most eight gaps can occur at a given position: a deletion event affecting all nine languages would not appear in the alignment and is explicitly conditioned on in the likelihood calculation"; Citep{Lunter2003}; DotSpace;
    "Gaps increase systematically from initial to final position, with word-final segments exhibiting substantially higher deletion rates. ";
    "A likelihood-ratio test rejects the null hypothesis that the gap distributions are identical across positions, (";

    EqSpan {ChiSquareTest; Tex.Equals; Span {TextDigits: 2; MainResults.MainRun.TestStatistic}}; CommaSpace;
    EqSpan {DegreesFreedom; Tex.Equals; 16}; CommaSpace;
    EqSpan {PValue; Tex.lt; 0.001};
     ") which confirms a statistically significant positional asymmetry. ";
  };

  override GetBody(ContentStyle style) = HBox {
    style.SansSerif;
    VAlign: Center;
    PaperStyle.ValueLabel {
      TextHeight: 12pt;
      "Proportion of Alignments"
    };
    var gaps        = MainResults.MainRun.GapSpectrum;
    var chartheight = (ExtentHeight - 40pt) / gaps.Length;
    VBox {
      HAlign: Center;
      foreach (var gap in gaps) {
        Chart(ExtentWidth - 20pt, Math.Min(chartheight, 1.2")) {
          ChartType: ChartTypes.Column;

          ValueLabel: PaperStyle.ValueLabel {
            TextHeight: 8pt;
            ["Word-initial seg.", "Word-internal seg(s)", "Word-final seg."][each0]
          };

          ValueAxis: ChartAxis {
            TextHeight: 7pt;
            Start: 0;
            Stop: 1.0;
          };

          XAxis: ChartAxis {
            each (0..<gap.Length step 1) as string;
          };

          ChartSeries {
            var factor = 1.0 / Math.Sum(gap);
            foreach (var value in gap)
              new DataPoint(each0, value * factor);
          };
        }
      }
      Span {
        TextHeight: 12pt;
        "Number of Gaps"
      };
    };
  };
}

