readonly WordSegmentRelSection PaperSections.WordSegmentRelationships = new;

class WordSegmentRelSection: Content {
  Constructor {
    super.Constructor("Segmental Alignments");
  }

  override GetBody(ContentStyle style) = Block {
    style.Par {
      var align1 = Figures.AlignmentExample1;
      var index1 = align1.Examples[0].FindAlignment(MainResults.MainRun);

       "In our framework, segmental homology across languages is treated as a latent random variable. ";
    "Posterior uncertainty over alignments is summarized by constructing a credible set for each cognate word form. ";
    "Alignments are ordered by posterior probability and the smallest set whose cumulative posterior mass reaches ";
    ExperimentResults.CutoffProbability;
    " is retained. ";
    style.FigureReference(align1);
    " illustrates this procedure for the concept ";
    style.SQuote {
      TextCase: TextCases.AllLower;
      align1.Examples[0].Concept;
    };
    DotSpace;
    "Three general properties emerge. ";

    "First, posterior mass is typically concentrated on a single dominant alignment. ";
    "In the example shown, the highest-probability alignment alone accounts for ";
    Span {
      TextDigits: 2;
      index1.Alignments[0].Prob;
    };
    " of the posterior. ";
    "Second, insertion and deletion events occur disproportionately in word-final position, consistent with the distribution of gap frequencies shown in ";
    style.FigureReference(Figures.GappinessChart);
    DotSpace;
    "Third, segments from the same natural class tend to be assigned to the same column in the alignment. ";
  };

    style.AddFigure(Figures.EquilibriumCharts, FigureOptions.Bottom, 80%);

    style.Par {
      var align2 = Figures.AlignmentExample2;

      style.ReviewMark(ReviewComments.C5);
      "The posterior distribution over alignments is sensitive to the substitution model. ";
      style.FigureReference(align2); " presents the {0} credible set of alignments for the concept "(ExperimentResults.CutoffPercent);
      style.SQuote {
        TextCase: TextCases.AllLower;
        align2.Concept
      };
      " under the ";
      style.TextList {
        align2.Models;
      };
      " models. ";


      "Under the ";
      align2.Poisson;
      " model, the credible set contains ";
      align2.Poisson.ShowAlignmentNumber;
      ", whereas under the ";
      align2.NaturalClass;
      " model it contains only ";
      align2.NaturalClass.ShowAlignmentNumber;
      DotSpace;

        "This reduction in alignment uncertainty accords with the substitution-rate structure estimated under the ";
      align2.NaturalClass;
      " model (";
      style.FigureReference(Figures.RateChart);
      "). ";
      "For instance, transitions between ";
      VocalSegments.u;
      " and ";
      VocalSegments.oh;
      " are assigned relatively high rates, whereas substitutions between consonants and ";
      VocalSegments.oh;
      " are strongly disfavored. ";
      "Consequently, the ";
      align2.Poisson;
      " model frequently aligns consonants with ";
      VocalSegments.oh;
      ", while such configurations receive negligible posterior weight under the ";
      align2.NaturalClass;
      " model. ";
    };

    style.AddFigure(Figures.RateChart, FigureOptions.Bottom | FigureOptions.Full, 60%);
  };
}

