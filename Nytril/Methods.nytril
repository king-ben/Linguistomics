  var ExperimentData Data;

  Constructor(ExperimentData data) {
    super.Constructor("Manual Alignment");
    Data = data;
  }

  override GetCaption(ContentStyle style) = Span {
    "Manual alignment of the words for the concept ";
    style.SQuote {
      TextCase: AllLower;
      Data.FigureConcept.Name;
      DotSpace;
    };
  };

  override GetBody(ContentStyle style) = LanguageTable([2"]) {
    LanguageTitleRow {
      Lang.Language; Lang.WordForms; Lang.SegmentCount;
    };

    foreach (var taxon in Data.Taxa) {
