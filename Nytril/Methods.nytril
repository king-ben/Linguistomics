readonly ModelInferenceSection PaperSections.ModelInference = new;

class ModelInferenceSection: Content {
  Constructor {
    super.Constructor("Model and Statistical Inference");
  }

  override GetBody(ContentStyle style) = Block {
    var rule = MainResults.Data.Rule;


style.Par {
  "We assume that the languages in our sample are related by an unknown phylogenetic tree, ";
  UnknownTree;
  ", which encodes both their branching structure ";
  SpanParens{Topology};
  " and the expected number of phonemic transition events ";
  ExpectedEvents;
  " along each branch. ";
  "Evolution of word forms along the tree is modeled under TKF91";
  Citep{Thorne1991};
  ", an event-based continuous-time process in which three instantaneous operations are permitted: segmental substitution, insertion, and deletion. ";
  "Insertions and deletions occur at rates ";
  InsertionRate;
  " and ";
  DeletionRate;
  ", respectively, subject to the constraint ";
  InsertionRateCondition;
  DotSpace;
  "Segmental substitution is modeled as a continuous-time Markov process whose states correspond to phonemes (the inventory comprises ";
  MainResults.Data.UniqueSegments.Length;
  " distinct segments). ";
  "All pairwise substitution rates are specified by the rate matrix ";
  RateMatrix;
  ", which is governed by parameters ";
  RateMatrixParams;
  DotSpace;
};

style.Par {
  "Parameter estimation is conducted within a Bayesian framework, with inference based on the joint posterior distribution of all model parameters: ";
};

style.AlignEquation(Equations.BayesianEstimation);

style.Par {
  SegmentalInfo;
  " denotes the observed segmental sequences of the cognate word forms. ";
  "The likelihood function, ";
  LiklihoodFunction;
  ", is evaluated using the dynamic programming algorithm of ";
  Citet{Lunter2003};
  DotSpace;
  "Prior distributions for most parameters follow conventions standard in phylogenetic modeling. ";
  "The insertion and deletion rate parameters, however, are assigned independent exponential priors subject to the constraint ";
  InsertionRateCondition;
  DotSpace;
  style.ReviewNew{
    "An alignment of length ";
    AlignmentLength;
    " is assigned a geometric prior with parameter ";
    InsertionProbability;
    DotSpace;
    "Under the TKF91 process, the equilibrium distribution of alignment lengths is geometric with parameter ";
    InsertionProbability;
    ", which motivates this choice. ";
    "A more principled alternative would specify a fully generative prior over alignments conditional on the insertion and deletion rates, derived directly from the TKF91 process. ";
    "The development of such priors for segmental homology structures remains an important objective for future research. ";
  }
};

style.Par {
  "The posterior distribution is approximated numerically using Markov chain Monte Carlo, or MCMC";
  Citep{Metropolis1953; Hastings1970}; DotSpace;
  "We construct a Markov chain whose state space consists of the full set of model parameters and whose stationary distribution coincides with the posterior distribution of interest. ";
  "After convergence, the samples drawn from this chain constitute dependent but valid draws from the posterior. ";
  "In addition to phylogenetic parameters, the MCMC algorithm jointly samples segmental alignments";
  Citep{Lunter2004};
  DotSpace;
};

style.AddTable(Figures.PartitionAssignments, FigureOptions.Bottom, 98%);

style.Par {
  style.ReviewMark(ReviewComments.C44);
  var number = Enumerators.Cardinal(rule.Filters.Length);
  "Segmental substitution is parameterized with reference to phonological natural classes, which are defined as sets of segments sharing phonetic features. ";
  "The segment inventory is exhaustively partitioned into ";
  number;
  " such classes, listed in ";
  style.TableReference(Figures.PartitionAssignments);
  DotSpace;
  "Under the ";
  NaturalModelName;
  ", transition rates are allowed to vary across these ";
  number;
  " classes. ";
  "The model includes ";
  MainResults.Data.UniqueSegments.Length;
  " parameters governing the equilibrium distribution and ";
  (rule.Filters.Length-1)^2-1;
  " parameters specifying exchange rates among natural classes. ";
  "Equilibrium frequencies are treated as random variables with a flat Dirichlet prior. ";
};

  };
}

