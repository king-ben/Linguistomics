readonly AlignmentFigure Figures.Alignment = new;

class AlignmentFigure: Content {
  const ArrowWidth  = 40;
  const Arrowhead   = 8pt;
  const ArrowColor  = 80%;

  const HMap1 = [
    "001111101",
    "100011111",
    "100011101",
    "011011011",
    "101010101",
    "101010100",
    "101010000",
    "010011101",
    "101011101",
    "100111011",
  ];

  const HMap2 = [
    "1111100001",
    "1001111001",
    "0101011010",
    "0001111110",
    "1010101001",
    "0001010110",
    "0001001001",
    "1001110001",
    "1111001001",
    "0101100111",
  ];

  Constructor {
    super.Constructor(Lang.Alignment);
  }

  TName(ContentStyle style, Taxon taxon) = Span {
    style.SansSerif;
    taxon.Language;
  };

  SegmentTable(ContentStyle style, ExperimentData data, ExampleConcept example, aligned) = MatrixBox {
    VAlign: Center;
    foreach (var taxon in data.Taxa) {
      Row {
        TName(style, taxon);
        Cell {
          IPAFamily;
          Span {
            var word = example.Cognate.Words[taxon.Index];
            var segs = aligned ? word.Padded : word.Segments;
            (each segs).ShowBlock;
          }
        };
      }
    }
  };

  MapTable(ContentStyle style, ExperimentData data, ExampleConcept example, map, text) = Block {
    IPAFamily;
    foreach (var taxon in data.Taxa) {
      Paragraph(null, [60pt]) {
        TName(style, taxon);
        Tab;
        var t        = map[each0];
        var segments = example.Cognate.Words[taxon.Index].Segments;
        if (text) {
          var i  = 0;
          foreach (var c in t) {
            if (c == '1' and i < segments.Length)
              segments[i++].ShowBlock;
            else
              VocalSegments.GapSegment.ShowBlock;
          }
        }
        else {
          int ones = 0;
          foreach (var c in t) {
            if (c == '1')
              ++ones;
            HBox(10pt) {HAlign: Center; c}
          }
          System.Assert(ones == segments.Length, taxon.ShortName);
        }
      }
    }
  };

  LabelBox(label) = HBox {
    Margin: PadR(5);
    TextHeight: 18pt;
    Bold;
    EqSpan {label};
  };

  ArrowFigure(Size size) = Canvas(size.Width, size.Height) {
    Shape(null, new(1.5, ArrowColor)) {
      OpenPath(0) {
        QuadTo(new(size.Width*0.92, size.Height*0.4), new(size.Width - Arrowhead*0.5, size.Height - Arrowhead));
      };
    };
    Shape(ArrowColor) {
      ClosedPath(size.Width - Arrowhead, size.Height - Arrowhead) {
        LineTo(size.Width, size.Height - Arrowhead);
        LineTo(size.Width - Arrowhead * 0.5, size.Height);
      };
    };
    Canvas {
      Background: Colors.White;
      X: size.Width * 0.3;
      Y: (size.Height - 60pt) * 0.5;
      TextHeight: 20pt;
      TextColor: ArrowColor;
      Bold;
      "+";
    };
  };

  HomBox(ContentStyle style, ExperimentData data, ExampleConcept example, num, Edge edge, map) = VBox {
    HAlign: Center;
    HBox {
      VAlign: Top;
      LabelBox(HomologyMap sub num);
      HBox(null, null, edge) {
        MapTable(style, data, example, map, false);
      };
    };
    Canvas {
      TextColor: ArrowColor;
      TextHeight: 20pt;
      HAlign: Center;
      Span {
        Tex.downarrow;
        X: 1pt;
      };
      "=";
    };
    HBox {
      VAlign: Top;
      LabelBox(SegmentalAlignment sub num);
      HBox(null, null, edge) {
        MapTable(style, data, example, map, true);
      };
    };
  };

  override GetCaption(ContentStyle style) = Span {
    "Alignments (";
    SegmentalAlignment;
    ") are formed from the observed segments (";
    SegmentalInfo;
    ") and a homology map (";
    HomologyMap;
    "). ";
  };

  override GetBody(ContentStyle style)= VBox {
    TextHeight: 10pt;
    Separation: 4pt;
    Margin: PadB(5pt);
    HAlign: Center;

    var data    = MainResults.Data;
    var example = new ExampleConcept(data, data.ExampleConcept);
    var edge    = new Edge(0.5pt, 2pt, ArrowColor);


    HBox {
      VAlign: Bottom;
      var fsize = new Size(ArrowWidth, data.Taxa.Length * 8pt);

      ArrowFigure(fsize) {
        Transform: new Transform(-1, 0, 0, 1, fsize.Width, 0);
      };
      HBox {
        VAlign: Top;
        LabelBox(SegmentalInfo);
        HBox(null, null, edge) {
          SegmentTable(style, data, example, false);
        };
      };
      ArrowFigure(fsize);
    };
    HBox {
      HomBox(style, data, example, 1, edge, HMap1);
      Separation: 24pt;
      HomBox(style, data, example, 2, edge, HMap2);
    }
  };
}

//======================================================================

namespace StateSection {
  MatrixRow(states, state) = {
    foreach (var s in states) {
      Cell {
        sym.q sub (state s);
      }
    }
  };

  StateRow(states, state) = Row {
    Cell(PadR(3pt)) {
      HAlign: Right;
      Span {
        each0 == states.Length div 2 ? "From   " : Empty;
        state;
      }
    };
    MatrixRow(states, state);
  };

  GetStates(count) = 'A'..('A' + (count - 1)) step 1;

  StateTable(count) = Table(new Thickness(1pt, 1pt, 3pt, null), null, [new(56pt, BorderR(PaperStyle.TableEdgeSize)), 32pt]) {
    ParAlignment: Center;
    VAlign: Center;
    HAlign: Center;

    var states = GetStates(count);
    Row {
      Empty;
      Cell(null, states.Length) {
        Lang.To;
      };
    };
    Row(BorderB(PaperStyle.TableEdgeSize)) {
      Empty;
      states;
    };
    StateRow(states, each states);
  };

  StateMatrix(count) = MatrixBox(PadB(3)) {
    var states = GetStates(count);

    Bracket: Brackets.FlatRound;
    foreach (var state in states) {
      Row {
        MatrixRow(states, state);
      }
    }
  };
}

