using Format;

//======================================================================

readonly namespace<ReviewComment> ReviewComments {}

readonly ReviewComment[] CommentList {
   return ReviewComments.ToSortedArray(false, @ReviewComment.CompareOrder);
}

readonly namespace<Person> Reviewers {
  R1 = new(#c2af5714-c3da-4e59-af0e-d6b1b181db8e#, "Reviewer 1", null, null);
  R2 = new(#8afa017a-9e98-42ef-9052-006768cbb043#, "Reviewer 2", null, null);
  R3 = new(#e72f0c0e-25f1-4751-9d75-a722c5392850#, "Reviewer 3", null, null);
}


readonly namespace<ReviewComment> ReviewComments;

C4 = new(#d0fe979b-9bf2-43cd-af5a-e2bc05c2bfda#, Reviewers.R1, People.Buchi_Éva) {
  Text: Paragraph {
    "I don’t think a direct comparison with any of those model is doable or interesting (although you mention that TKF91 is not primarily used to infer the phylogeny and thus Bouchard-Côté is your direct competitor), but I would think some more questions can be asked based on those articles (I am not a specialist of Romance languages so some remarks might just mean additional details on the specificities of this domain is needed). ";
    "I mention those questions in the next parts.";
  };
  Response: "This comment is addressed in subsequent responses.";
};

C34 = new(#8402afbe-14ee-460e-85c2-aaa8d72d481c#, Reviewers.R2, People.Buchi_Éva) {
  Text: "\"(DÉRom, 2023)\"? ";
  Response: "N.B. the ATILF is getting rid of the Stella-server, so this URL will soon no longer work, whereas the “generic” URL will always be maintained.";
};

C23 = new(#dea1d699-0d2c-4f05-9a20-9e6d220f3414#, Reviewers.R1, People.McCreight_Shawn) {
  Text: Paragraph {
    "p7: lieasinabed, the whole list should go in appendix.";
