readonly ExperimentResults MainResults = new;

class ExperimentResults {
  var ExperimentData   Data;
  var RunResultsThread Poisson,
                       NaturalClass,
                       MainRun;
  var AlignmentChart   Alignment;

  Constructor {
    Data = new("Europe3", 1..3);
    Data.ReadExperiment;

    var set = Data.TreeSets[0];

    Poisson      = new(Data, set.Models[1].Run[1]); // For some reason, this run succeeded but not Run[0]
    NaturalClass = new(Data, set.Models[0].Run[0]);
    MainRun      = NaturalClass;
    Parallel.ParallelEach([Poisson, NaturalClass], 100%);

    Alignment = new(Data, MainRun);
  }
}

