class BioSummary: Fact {
  field string Text;
  var Person   Author;

  Constructor(Person author, text) {
    super.Constructor(author.FactId);
    Text   = text;
    Author = author;
  }
}

readonly namespace<BioSummary> BioSummaries {
  David = new(People.Goldstein_David, "A. Richard Diebold Jr. Professor of Indo-European Studies, Professor of Linguistics, Professor of Classics, University of California, Los Angeles");
  Shawn = new(People.McCreight_Shawn, "Founded Guidance Software, Inc. in 1997 and served as Chairman and CTO until 2016. Founded Nytril LLC in 2017 and currently serves as CEO and software architect. He is currently developing the Nytril platform to enable the creation of computable documentation.");
  Eva   = new(People.Buchi_Éva, "Senior researcher at CNRS (ATILF, Nancy) and a lecturer at Université de Lorraine. Her research focuses on historical Romance linguistics, particularly etymology. She published in 1996 a monograph on the \"Französisches Etymologisches Wörterbuch\" (FEW) and in 2010 a dictionary of Romance loanwords from Russian. Together with Wolfgang Schweickard (Saarland University), she heads the \"Dictionnaire Étymologique Roman\" (DÉRom, 2008). Currently she is working on a handbook of Romance lexical etymology she has been commissioned to edit for De Gruyter’s Manuals of Romance Linguistics (MRL) series.");
  John  = new(People.Huelsenbeck_John, "McCreight Chancellor's Chair in Computational Biology, Professor of Integrative Biology, University of California, Berkeley");
}

//===============================================================

class JOLEStyle: OUPStyle {
  Constructor(TemplateOptions options) {
    super.Constructor("Journal of Language Evolution", options | SectionNumbers);
    TexPackages.AddEach(["fontspec"]);
    TexFont   = "Libertinus Serif";
    SansSerif = TextFamily: TextFamilies.LibertinusSans;
  }

  override SetTextStyle = {
    TextHeight: 12pt;
    TextFamily: TextFamilies.LibertinusSerif;
  };
}

//===============================================================

class PlainStyle: ContentStyle {
  Constructor {
    super.Constructor(ReferenceStyles.IEEE, null, 0.75", SectionNumbers);
    TexPackages.AddEach(["fontspec"]);
    TexFont   = "Libertinus Serif";
    SansSerif = TextFamily: TextFamilies.LibertinusSans;
  }

  override SetTextStyle = {
    TextHeight: 12pt;
    TextFamily: TextFamilies.LibertinusSerif;
  };
}

//===============================================================

class OtherStyle: PNASStyle {
  Constructor {
    super.Constructor(null, LineNumbers | TwoColumn);
    TexPackages.AddEach(["jabbrv", "fontspec", "noto", "xspace"]);
  }

  override SetTextStyle = {
    TextFamily: TextFamilies.LibertinusSerif;
    TextHeight: 9pt;
  };
}

//===============================================================

class HomePage: SitePage {
  Constructor {
    super.Constructor(Main.Site, #29f0a41f-f0f2-4830-bcaa-70418aa20157#, "Home", "Linguistics Research Project");

    Tiles = [
      new DocTile(Main.Documents.PaperJOLE, Icons.article, "Paper"),
      new DocTile(Main.Documents.Supplemental, Icons.add_circle),
      new DocTile(Main.Documents.Diagnostic, Icons.settings),
      new DocTile(Main.Documents.Biography, Icons.person_search, "Acknowlegments") {Description: "Author bios and comments"},
    ];
  }

  override GetHeader = Block {
    Paragraph {
      TextHeight: 20pt;
      SpaceAfter: 20pt;
      MainPaper.Title;
    };

    FinalStyle.ShowAuthorList(MainPaper, true);
    Paragraph {
      SpaceAfter: 20pt;
    };
  };
}

//===============================================================

class LinguistomicsSite: RealmSite {
  Constructor {
    super.Constructor("Linguistomics");
  }

  override GetLayoutIcon = HBox {
    TextHeight: 48pt;
    VAlign: Bottom;
    Shape(NytrilPalette.IconBack, Colors.White) {
      Icons.spatial_audio_off;
    };
  };

  override GetLayoutBug = GetLayoutIcon;

  override GetLayoutLogo = HBox {
    VAlign: Center;
    TextHeight: 48pt;
    var c = NytrilPalette.IconBack;

    Shape(c, Colors.White) {
      VAlignment: VAligns.Bottom;
      Icons.spatial_audio_off;
    };
    Shape(c, Colors.White) {
      VAlignment: VAligns.Top;
      HAlignment: HAligns.Right;
      Icons.psychology;
    };
  };

  override GetLayoutSiteLogo = GetLayoutLogo;
}

